{
  "name": "@veo/utils",
  "version": "0.1.0",
  "private": true,
  "description": "Helpers compartidos: crypto, date, geo (H3), validation, logger, errors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "@veo/shared-types": "workspace:*",
    "date-fns": "^3.6.0",
    "h3-js": "^4.1.0",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  }
}

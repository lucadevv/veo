{
  "name": "@veo/rpc",
  "version": "0.1.0",
  "private": true,
  "description": "Toolkit downstream BFF→microservicio: clientes gRPC (lecturas) + REST interno firmado HMAC (comandos)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "sync:protos": "node scripts/sync-protos.mjs",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.2",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/common": "^10.4.4",
    "@veo/auth": "workspace:*",
    "@veo/observability": "workspace:*",
    "@veo/shared-types": "workspace:*",
    "@veo/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "files": ["dist", "proto"]
}

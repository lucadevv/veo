{
  "name": "@veo/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "Contrato tipado BFF↔web (REST + Socket.IO) y cliente HTTP basado en fetch",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@veo/shared-types": "workspace:*",
    "@veo/utils": "workspace:*",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "rimraf": "^6.0.1"
  },"dependencies": { "zod": "^3.23.8" }
}

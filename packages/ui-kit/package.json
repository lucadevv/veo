{
  "name": "@veo/ui-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de diseño móvil VEO: tokens + componentes React Native compartidos por passenger y driver",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-native": "0.75.4",
    "react-native-reanimated": ">=3.15.0 <4",
    "react-native-safe-area-context": ">=4.11.0 <5",
    "react-native-svg": ">=15.0.0 <16"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "react": "18.3.1",
    "react-native": "0.75.4",
    "react-native-reanimated": "3.15.4",
    "react-native-safe-area-context": "4.11.0",
    "react-native-svg": "15.8.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}

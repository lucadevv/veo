{
  "name": "@veo/design-tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Tokens semánticos de la identidad Trust de VEO (TS puro, platform-agnostic): la ÚNICA fuente de hex del sistema. Consumido por @veo/ui-kit (RN) y por el codegen de tokens.css (web).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:css": "tsc -p tsconfig.json && node scripts/generate-css.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}

{
  "name": "@veo/auth",
  "version": "0.1.0",
  "private": true,
  "description": "JWT signing/validation, guards NestJS, decorators, strategies (compartidos por servicios)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "jose": "^5.9.4",
    "ioredis": "^5.4.1",
    "otplib": "^12.0.1",
    "@veo/shared-types": "workspace:*",
    "@veo/utils": "workspace:*"
  }
}

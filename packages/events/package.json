{
  "name": "@veo/events",
  "version": "0.1.0",
  "private": true,
  "description": "Schemas de eventos Kafka con validación Zod y tipos TS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "zod": "^3.23.8",
    "kafkajs": "^2.2.4",
    "@veo/utils": "workspace:*"
  }
}

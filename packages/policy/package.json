{
  "name": "@veo/policy",
  "version": "0.1.0",
  "private": true,
  "description": "PBAC (ADR-024): contrato liviano de las 16 políticas (tipos, catálogo Zod, defaults, interfaz PolicyReader) en el entry raíz + cliente runtime cacheado (KafkaCachedPolicyReader + PolicyModule) en el subpath @veo/policy/nest.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nest": {
      "types": "./dist/nest.d.ts",
      "default": "./dist/nest.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "nest": [
        "./dist/nest.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "zod": "^3.23.8",
    "@nestjs/common": "^10.4.4",
    "@veo/auth": "workspace:*",
    "@veo/events": "workspace:*",
    "@veo/rpc": "workspace:*",
    "@veo/shared-types": "workspace:*"
  }
}

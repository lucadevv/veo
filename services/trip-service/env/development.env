# trip-service · config DEV (tracked, SIN secretos). El INTERNAL_IDENTITY_SECRET vive en
# development.secret.env (gitignored), generado por dev-stack/boot-passenger-stack.sh (sincronizado con bff/identity).
NODE_ENV=development
# Puerto HTTP DEV: 3092 (canónico 3002 en FOUNDATION). Override LOCAL para esquivar app-sendio,
# que ocupa 3002/3003 en este host. El gRPC (50052) NO cambia. Mismo patrón que identity (3001→3091).
PORT=3092
LOG_LEVEL=info

# Postgres compartido del dev-stack (contenedor veo-postgres, schema propio del servicio).
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=trip

# Redis + Kafka del dev-stack.
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9094

# gRPC server (lecturas síncronas desde el BFF). El bff apunta a TRIP_GRPC_URL=localhost:50052 por default.
GRPC_URL=0.0.0.0:50052

# Mapas: motor LOCAL determinista (sin OSRM/Mapbox en dev). Suficiente para rutas/ETA del viaje.
VEO_MAPS_MODE=local

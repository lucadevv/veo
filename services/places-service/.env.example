# places-service · variables de entorno (copiar a .env). Validadas por src/config/env.schema.ts.

NODE_ENV=development
PORT=3013
LOG_LEVEL=debug

# Base de datos (schema "places"). El schema lógico se aísla con ?schema=places.
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=places
DATABASE_URL_REPLICA=postgresql://veo:veo_dev@localhost:5433/veo?schema=places

# Redis (readiness + rate-limit; compartido con el resto del dev-stack)
REDIS_URL=redis://localhost:6379

# Reglas de negocio (server-side)
MAX_FAVORITES=20
MAX_PLACE_LABEL_LENGTH=40

# Secreto de identidad interna que el BFF propaga a los servicios (HMAC). KMS/Secrets Manager en prod.
INTERNAL_IDENTITY_SECRET=dev-internal-secret-change-me

# Observabilidad
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# gRPC (CRUD síncrono consumido por el public-bff)
GRPC_URL=0.0.0.0:50063

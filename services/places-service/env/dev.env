# places-service · entorno DEV (tracked, sin secretos reales). Cargar antes de bootear en local.
# Convención del repo (igual que identity/share): config NO secreta acá; los secretos van en
# `dev.secret.env` (gitignored). En dev los defaults del env.schema ya bastan para arrancar.
NODE_ENV=development
PORT=3013
LOG_LEVEL=debug
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=places
DATABASE_URL_REPLICA=postgresql://veo:veo_dev@localhost:5433/veo?schema=places
REDIS_URL=redis://localhost:6379
GRPC_URL=0.0.0.0:50063
# Secreto: vacío acá; el valor real (si difiere del default dev) vive en dev.secret.env (gitignored).
INTERNAL_IDENTITY_SECRET=

# share-service · entorno DEV (tracked, sin secretos reales). Cargar antes de bootear en local.
# Convención del repo (igual que identity/places): config NO secreta acá; los secretos van en
# `development.secret.env` (gitignored). En dev los defaults del env.schema ya bastan para arrancar.
NODE_ENV=development
PORT=3011
LOG_LEVEL=debug

# Base de datos (schema "share") — veo-postgres en :5433.
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=share
DATABASE_URL_REPLICA=postgresql://veo:veo_dev@localhost:5433/veo?schema=share

# Redis (OTP de contactos + cool-down de la lista + rate-limit) — veo-redis en :6379.
REDIS_URL=redis://localhost:6379

# Kafka (outbox relay + consumidores) — veo-kafka en :9094.
KAFKA_BROKERS=localhost:9094
KAFKA_CONSUMER_GROUP=share-service

# ── Enlace de seguimiento (config pública; el secreto de firma va en development.secret.env) ──
SHARE_LINK_TTL_SECONDS=7200
SHARE_LINK_MAX_USES=500
SHARE_PUBLIC_BASE_URL=http://localhost:3011/api/v1/public/share

# Contactos de confianza (BR-I06)
MAX_TRUSTED_CONTACTS=3
CONTACT_MODIFY_COOLDOWN_HOURS=24

# OTP de verificación del contacto
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3

# Puerto SMS (sandbox imprime el código/enlace; live = gateway operador).
VEO_SMS_MODE=sandbox

# Observabilidad (Jaeger OTLP del dev-stack).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# gRPC (lectura síncrona desde notification/panic).
GRPC_URL=0.0.0.0:50061

# Secretos: vacíos acá; los valores reales viven en development.secret.env (gitignored).
SHARE_LINK_SECRET=
INTERNAL_IDENTITY_SECRET=

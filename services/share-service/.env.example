# share-service · variables de entorno (copiar a .env). Validadas por src/config/env.schema.ts.

NODE_ENV=development
PORT=3011
LOG_LEVEL=debug

# Base de datos (schema "share")
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo
DATABASE_URL_REPLICA=postgresql://veo:veo_dev@localhost:5433/veo

# Redis (OTP de contactos + cool-down de la lista)
REDIS_URL=redis://localhost:6379

# Kafka (outbox relay + consumidores)
KAFKA_BROKERS=localhost:9094
KAFKA_CONSUMER_GROUP=share-service

# Enlace de seguimiento firmado (HMAC). En prod: Secrets Manager / KMS.
SHARE_LINK_SECRET=dev-share-link-secret-change-me
SHARE_LINK_TTL_SECONDS=7200
SHARE_LINK_MAX_USES=500
SHARE_PUBLIC_BASE_URL=http://localhost:3011/api/v1/public/share

# Contactos de confianza (BR-I06)
MAX_TRUSTED_CONTACTS=3
CONTACT_MODIFY_COOLDOWN_HOURS=24
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3

# Puerto SMS. Default 'sandbox' (loguea, no envía). En 'live' el adaptador delega la entrega del OTP
# de contacto a notification-service por REST FIRMADO (POST /notifications, reusa el template
# contact.otp + payload.code + priority Critical). NOTIFICATION_* tienen default en el schema.
VEO_SMS_MODE=sandbox
NOTIFICATION_INTERNAL_URL=http://localhost:3008/api/v1
NOTIFICATION_TIMEOUT_MS=8000

# Identidad interna propagada por el BFF
INTERNAL_IDENTITY_SECRET=dev-internal-secret-change-me

# Observabilidad
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# gRPC
GRPC_URL=0.0.0.0:50061

{
  "name": "@veo/identity-service",
  "version": "0.1.0",
  "private": true,
  "description": "Auth, KYC, JWT, biometric verification orchestrator",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "codegen": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "db:seed": "tsx scripts/seed.ts",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.2.3",
    "@veo/auth": "workspace:*",
    "@veo/database": "workspace:*",
    "@veo/events": "workspace:*",
    "@veo/observability": "workspace:*",
    "@veo/redis": "workspace:*",
    "@veo/shared-types": "workspace:*",
    "@veo/utils": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "@prisma/client": "^5.20.0",
    "prisma": "^5.20.0",
    "@nestjs/microservices": "^10.4.4",
    "@grpc/grpc-js": "^1.12.2",
    "@grpc/proto-loader": "^0.7.13",
    "argon2": "^0.41.1",
    "ioredis": "^5.4.1",
    "jose": "^5.9.4",
    "kafkajs": "^2.2.4",
    "nodemailer": "^6.9.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.4",
    "@types/node": "^20.16.10",
    "@types/nodemailer": "^6.4.16",
    "otplib": "^12.0.1",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}

# identity-service · entorno DEV (tracked, SIN secretos). Cargar antes de bootear en local.
# Convención del repo (igual que places): config NO secreta acá; los secretos (keypair JWT + HMAC
# interno) van en `development.secret.env` (GITIGNORED), generado por dev-stack/boot-passenger-stack.sh.
NODE_ENV=development
PORT=3091
LOG_LEVEL=debug

# Base de datos (schema "identity") — veo-postgres en :5433.
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=identity
DATABASE_URL_REPLICA=postgresql://veo:veo_dev@localhost:5433/veo?schema=identity

# Redis (OTP store + refresh sessions + rate limit) — veo-redis en :6379.
REDIS_URL=redis://localhost:6379

# Kafka (outbox relay) — veo-kafka en :9094.
KAFKA_BROKERS=localhost:9094

# JWT ES256 — issuer/audience deben coincidir con los del public-bff (VEO_JWT_ISSUER/AUDIENCE).
JWT_ISSUER=veo-identity
JWT_AUDIENCE=veo-app
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OAuth soberano (ADR-012): 'live' verifica el id_token REAL contra el JWKS de Google/Apple
# (firma+iss+aud+exp). 'sandbox' (default) espera tokens FIXTURE → rompe el Sign in with Apple/Google
# real de la app ("token inválido"). Los Client IDs son PÚBLICOS (embebidos en el binario), no secretos.
VEO_OAUTH_MODE=live
APPLE_CLIENT_ID=pe.veo.passenger
GOOGLE_CLIENT_ID=421526184282-sfg0u6jp63s92dr3j3aaoulmvg3fp750.apps.googleusercontent.com,421526184282-nna35hfqa0fjuej3ja2ts96795bqpse8.apps.googleusercontent.com

# Correo en sandbox: NO envía, loguea el código de verificación (lo leemos del log para el chain dev).
VEO_EMAIL_MODE=sandbox

# gRPC (lectura síncrona desde otros servicios; el public-bff usa IDENTITY_GRPC_URL=localhost:50051).
GRPC_URL=0.0.0.0:50051

# Observabilidad (Jaeger OTLP del dev-stack).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

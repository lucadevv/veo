# identity-service · secretos DEV (PLANTILLA tracked). Copiar a `development.env` (GITIGNORED) y completar.
# El boot del passenger-stack (dev-stack/boot-passenger-stack.sh) genera el development.env real
# con un keypair ES256 (EC P-256) PERSISTENTE y consistente con el public-bff.
#
# JWT ES256: privada PKCS#8 + pública SPKI. La MISMA pública va en public-bff (VEO_JWT_PUBLIC_PEM).
# Si faltan, identity genera un par EFÍMERO en cada arranque → el BFF valida con otro → 401. NO dejar vacío en uso real.
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
# HMAC de identidad interna (firma la identidad propagada BFF→service). DEBE ser IDÉNTICO en
# TODOS los consumidores: los services (identity, places, dispatch, panic, audit, fleet, notification,
# trip, payment, media, rating, share, chat) y los 3 BFFs (public/driver/admin, donde la var se
# llama VEO_INTERNAL_IDENTITY_SECRET). Si difiere entre dos, el guard interno rechaza la request.
# La identidad firmada ahora porta además un claim de RIEL `aud` (public/driver/admin/service-rail),
# verificado per-service fail-closed. Es una constante de compilación (NO un env): no se agrega var nueva.
INTERNAL_IDENTITY_SECRET=
# Salt del hash del DNI (PII no reversible). secret() → falla en prod si falta o es el de dev.
DNI_HASH_SALT=
# Clave de cifrado del secreto TOTP (2FA). secret() → falla en prod si falta o es el de dev.
TOTP_ENC_KEY=
# URL pública del panel admin-web (NO secreto): base del link de invitación de operadores
# (`${ADMIN_WEB_URL}/accept-invite?token=...`). Requerida (z.string().url()). Ej: http://localhost:5001
ADMIN_WEB_URL=

# Lockout anti brute-force (login por correo de pasajeros Y login de operadores admin + TOTP).
# Fallos consecutivos antes de bloquear y duración del bloqueo (= ventana de conteo). Tienen default
# en el schema (5 / 900s), así que son opcionales; descomentá para ajustar.
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCK_SECONDS=900

# SMS del OTP. Default 'sandbox' (loguea el código en consola, no envía nada real). En 'live' el
# adaptador delega la entrega del OTP a notification-service por REST FIRMADO (POST /notifications,
# reusa el template contact.otp + payload.code + priority Critical). Tienen default en el schema;
# descomentá para activar live o apuntar a otro notification. La URL apunta a la API interna (/api/v1).
# VEO_SMS_MODE=sandbox
# NOTIFICATION_INTERNAL_URL=http://localhost:3008/api/v1
# NOTIFICATION_TIMEOUT_MS=8000

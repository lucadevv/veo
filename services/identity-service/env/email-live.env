# Identity · envío de correo LIVE (Resend.com vía SMTP) — config NO secreta (tracked).
# Soberanía §0.7: Resend es un RIEL DE ENTREGA detrás del puerto EmailSender (como el operador de SMS);
# la lógica de OTP/cuentas es nuestra. Intercambiable por otro relay sin tocar el dominio.
# El secreto (SMTP_PASS = API key de Resend) va en `email-live.secret.env` (gitignored).
#
# Uso (validación / staging-prod): cargar este archivo + el .secret.env antes de bootear identity.
# En dev/local el default es sandbox (mailpit), NO se usa este archivo.
VEO_EMAIL_MODE=live
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
# Remitente: para validar sin dominio verificado, Resend permite onboarding@resend.dev (solo entrega al
# dueño de la cuenta). En prod, usar un dominio verificado en Resend (ej. no-reply@veo.pe).
SMTP_FROM='VEO <onboarding@resend.dev>'
# Secreto: vacío acá; el valor real vive en email-live.secret.env (gitignored).
SMTP_PASS=

// identity-service · esquema Postgres (schema lógico "identity")
// FOUNDATION §8. Dueño de: identidad de personas (pasajeros, conductores), auth y operadores admin.
// Veículos y documentos viven en fleet-service. Contactos de confianza en share-service.

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity"]
}

enum UserType {
  PASSENGER
  DRIVER

  @@schema("identity")
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED

  @@schema("identity")
}

enum DriverStatus {
  OFFLINE
  AVAILABLE
  ASSIGNED
  ON_TRIP
  ON_BREAK
  SUSPENDED

  @@schema("identity")
}

enum BackgroundCheckStatus {
  PENDING
  CLEARED
  REJECTED

  @@schema("identity")
}

/// ORIGEN de una suspensión del conductor (discriminador del `suspendedAt`, fail-closed). El modelo
/// Driver modela la suspensión 100% por el timestamp `suspendedAt`, pero hay DOS fuentes con semánticas
/// de reversión distintas que antes no se podían distinguir: la reactivación del operador NO debe poder
/// levantar una suspensión por documentos vencidos (re-habilitar a un conductor con SOAT/licencia
/// vencida es un bug de seguridad inaceptable). Este enum permite gatear la reactivación por origen.
enum SuspensionSource {
  DISCIPLINARY // suspensión MANUAL del operador (suspend()) — reversible por el operador
  DOCUMENT_EXPIRED // suspensión AUTOMÁTICA por documento crítico vencido (fleet.driver_suspended) — NO reversible a mano

  @@schema("identity")
}

enum BiometricCheckType {
  SHIFT_START
  REVERIFY
  ONBOARDING

  @@schema("identity")
}

enum AdminStatus {
  PENDING
  INVITED
  ACTIVE
  SUSPENDED
  REJECTED

  @@schema("identity")
}

/// Método de autenticación soberano de un usuario (ADR-012). Un User puede tener varios
/// (teléfono+OTP, correo+contraseña, Google OAuth) vinculados a la misma identidad.
enum AuthMethodType {
  PHONE_OTP
  EMAIL_PASSWORD
  GOOGLE_OAUTH
  APPLE_OAUTH

  @@schema("identity")
}

/// Tipo de documento de identidad del pasajero (Perú · ProntoPaga). Vive en el PERFIL para
/// soportar la afiliación Yape de UN TAP (patrón PedidosYa): el documento se guarda una vez y el
/// BFF lo reutiliza sin pedirlo en cada checkout. DN = DNI (8 díg) · CE = carné de extranjería
/// (9-12 díg) · PP = pasaporte (6-12 alfanum).
enum DocumentType {
  DN
  CE
  PP

  @@schema("identity")
}

/// Estado de un vínculo de referido (Ola 2A).
enum ReferralStatus {
  PENDING // vinculado, recompensa aún no otorgada
  REWARDED // referido cumplió la condición (1er viaje) → recompensa otorgada

  @@schema("identity")
}

/// Identidad base de un usuario de las apps (pasajero o conductor).
model User {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Teléfono (login por OTP). Nullable porque un usuario puede registrarse SOLO por
  /// correo+contraseña o Google (ADR-012). Sigue siendo @unique (Postgres permite múltiples NULL).
  phone     String?    @unique
  email     String?
  /// Nombre visible del usuario (pasajero). Opcional; se valida 1–80 chars en el borde (DTO).
  name      String?    @map("name")
  type      UserType
  photoUrl  String?    @map("photo_url")
  /// Hash del DNI (nunca el DNI en claro — Ley 29733, decisión "solo hash").
  dniHash   String?    @map("dni_hash")
  /// Documento de identidad del PASAJERO para pagos (ProntoPaga · Yape On File). Vive en el perfil
  /// (no en el checkout): se carga UNA vez y el BFF lo reutiliza para afiliar Yape en UN TAP. Nullable
  /// hasta que el usuario lo registra. Es SU dato (owner-only por JWT); la UI decide cómo enmascararlo.
  documentType DocumentType? @map("document_type")
  /// Número del documento (forma según documentType: DN=8 díg · CE 9-12 díg · PP 6-12 alfanum).
  document     String?       @map("document")
  /// Método de pago POR DEFECTO del pasajero (preferencia de UI, no transacción): siembra el selector
  /// al pedir viaje. String (validado contra el enum PaymentMethod de @veo/shared-types en el borde DTO,
  /// no enum de DB para no acoplar el schema). Nullable = nunca lo eligió → la app cae a su default local.
  defaultPaymentMethod String? @map("default_payment_method")
  kycStatus KycStatus  @default(PENDING) @map("kyc_status")
  /// Embedding facial de referencia (ArcFace, 512-d) capturado al verificar KYC del pasajero.
  /// Vacío = pasajero NO verificado biométricamente.
  faceEmbedding Float[] @default([]) @map("face_embedding")
  /// Momento en que el pasajero pasó el liveness y quedó VERIFIED. Null = no verificado.
  kycVerifiedAt DateTime? @map("kyc_verified_at") @db.Timestamptz
  /// Código de referido único del usuario (Ola 2A). Se genera perezosamente la 1ª vez que se consulta.
  referralCode String?    @unique @map("referral_code")
  /// Crédito acumulado por referidos completados (céntimos PEN), modelado como recompensa simple.
  referralRewardCents Int  @default(0) @map("referral_reward_cents")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  /// Solicitud de borrado (BR-S06): inicia la gracia de 30 días antes del tombstone.
  deletionRequestedAt DateTime? @map("deletion_requested_at") @db.Timestamptz
  /// Tombstone (BR-S06 derecho al olvido).
  deletedAt DateTime?  @map("deleted_at") @db.Timestamptz

  driver           Driver?
  biometricChecks  BiometricCheck[]
  authMethods      AuthMethod[]

  @@index([kycStatus])
  @@map("users")
  @@schema("identity")
}

/// Credencial por método de autenticación (ADR-012 §2). El dominio de auth depende de esta tabla
/// para multi-método + account-linking. Tokens efímeros (verificación correo, reset) van en Redis.
model AuthMethod {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          AuthMethodType
  // EMAIL_PASSWORD: correo verificado antes de operar (Ley 29733) + hash argon2id.
  email         String?
  passwordHash  String?        @map("password_hash")
  emailVerified Boolean        @default(false) @map("email_verified")
  // OAUTH (Google): `sub` del IdP, verificado server-side.
  oauthSubject  String?        @map("oauth_subject")
  // Estado general del método (PHONE_OTP/EMAIL verificado, OAuth vinculado).
  verified      Boolean        @default(false)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([userId, type])
  @@unique([type, email])
  @@unique([type, oauthSubject])
  @@map("auth_methods")
  @@schema("identity")
}

/// Perfil específico del conductor (extiende User). Vehículo/documentos → fleet-service.
model Driver {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String                @unique @map("user_id") @db.Uuid
  user                  User                  @relation(fields: [userId], references: [id])
  licenseNumber         String?               @map("license_number")
  licenseExpiresAt      DateTime?             @map("license_expires_at") @db.Timestamptz
  /// Datos personales del conductor (BR-I04 cumplimiento). Opcionales hasta que el conductor los registra.
  legalName             String?               @map("legal_name")
  /// DNI peruano (8 dígitos). PII Ley 29733: se persiste CIFRADO en reposo (AES-256-GCM, secret-box,
  /// formato `iv.tag.enc` base64) — NUNCA en claro. Compliance lo MUESTRA al operador para verificación
  /// manual contra el documento, por eso es cifrado REVERSIBLE (no hash): identity descifra en el borde
  /// gRPC con `open()` antes de mandarlo al admin-bff (ya gateado Compliance+). El `User.dniHash` es OTRO
  /// caso (matching interno irreversible) — no se mezcla con este. Nullable hasta que el conductor lo registra.
  documentIdEnc         String?               @map("document_id_enc")
  birthDate             DateTime?             @map("birth_date") @db.Date
  currentStatus         DriverStatus          @default(OFFLINE) @map("current_status")
  averageRating         Decimal               @default(5.0) @map("average_rating") @db.Decimal(3, 2)
  totalTrips            Int                   @default(0) @map("total_trips")
  backgroundCheckStatus BackgroundCheckStatus @default(PENDING) @map("background_check_status")
  /// Última verificación biométrica exitosa que habilitó turno.
  lastVerifiedAt        DateTime?             @map("last_verified_at") @db.Timestamptz
  /// Embedding facial de referencia (ArcFace, 512-d) capturado en el enrolamiento (BR-I02).
  /// Vacío = conductor NO enrolado biométricamente (no puede iniciar turno en modo live).
  faceEmbedding         Float[]               @map("face_embedding")
  /// Momento del enrolamiento facial. Null = no enrolado.
  faceEnrolledAt        DateTime?             @map("face_enrolled_at") @db.Timestamptz
  /// Sub-lote 3C · BINDING DNI↔selfie. Resultado del face-match entre la foto FRONT del DNI (de S3, que el
  /// admin-bff baja) y el `faceEmbedding` de referencia GUARDADO del conductor. El operador lo VE antes de
  /// aprobar (no aprueba a ciegas). Nullable = aún no se corrió el match. `dniFaceMatched` = veredicto
  /// (true coincide / false no coincide); `dniFaceMatchScore` = 0..100; `dniFaceMatchedAt` = cuándo se corrió.
  dniFaceMatched        Boolean?              @map("dni_face_matched")
  dniFaceMatchScore     Float?                @map("dni_face_match_score")
  dniFaceMatchedAt      DateTime?             @map("dni_face_matched_at") @db.Timestamptz
  suspendedAt           DateTime?             @map("suspended_at") @db.Timestamptz
  /// ORIGEN de la suspensión vigente (POR QUÉ el conductor está suspendido). Null cuando NO está suspendido.
  /// Discrimina la reversión: la reactivación del operador solo puede levantar suspensiones DISCIPLINARY
  /// (las que él originó); las DOCUMENT_EXPIRED (documento crítico vencido) NO se levantan a mano — se
  /// levantan cuando el conductor regulariza sus documentos (fail-closed, seguridad Ley 29733). Filas
  /// legacy con suspendedAt seteado pero suspensionSource null se tratan como NO-DISCIPLINARY (rechazadas).
  suspensionSource      SuspensionSource?     @map("suspension_source")
  /// Motivo del último rechazo de antecedentes (texto del operador). Null si nunca fue rechazado o si se
  /// re-aprobó / reenvió. Lo expone el driver-bff (GET /drivers/me) para la pantalla de rechazo de la app.
  rejectionReason       String?               @map("rejection_reason")
  /// Momento del último rechazo de antecedentes (ISO). Null si nunca fue rechazado.
  rejectedAt            DateTime?             @map("rejected_at") @db.Timestamptz
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  @@index([currentStatus])
  @@map("drivers")
  @@schema("identity")
}

/// Operador del panel admin (no es usuario de las apps). Email+password(argon2id)+TOTP.
model AdminUser {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  /// Hash argon2id de la contraseña. Null mientras el operador está INVITED (aún no la fijó).
  passwordHash String?  @map("password_hash")
  /// Roles RBAC (AdminRole[] de @veo/shared-types) serializados.
  roles        String[]
  /// Secreto TOTP cifrado (KMS en prod). Null hasta enrolar.
  totpSecretEnc String? @map("totp_secret_enc")
  totpEnrolled Boolean  @default(false) @map("totp_enrolled")
  /// Onboarding por invitación (superadmin crea → INVITED + token de un solo uso; el operador fija
  /// su contraseña → ACTIVE). Hash sha256 del token de invitación (nunca el token en claro). Null tras
  /// aceptar/expirar: limpiarlo invalida el token (un solo uso).
  inviteTokenHash String? @map("invite_token_hash")
  /// Expiración de la invitación (48h). Null si no hay invitación pendiente.
  inviteExpiresAt DateTime? @map("invite_expires_at") @db.Timestamptz
  /// Auto-registro → PENDING; un ADMIN aprueba y asigna roles → ACTIVE.
  status       AdminStatus @default(PENDING)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  @@map("admin_users")
  @@schema("identity")
}

/// Registro de cada intento de verificación biométrica (auditable).
model BiometricCheck {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  user      User               @relation(fields: [userId], references: [id])
  type      BiometricCheckType
  /// Score 0..100 del match/liveness devuelto por biometric-service.
  score     Int
  passed    Boolean
  /// Referencia opcional a la captura cifrada (S3, gestionada por media-service).
  captureRef String?           @map("capture_ref")
  geoLat    Float?             @map("geo_lat")
  geoLon    Float?             @map("geo_lon")
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, createdAt])
  @@map("biometric_checks")
  @@schema("identity")
}

/// Vínculo referidor↔referido (Ola 2A). Un usuario puede ser referido UNA sola vez
/// (`referredUserId` UNIQUE). La recompensa se otorga al completar la condición (1er viaje del
/// referido); modelada como crédito en céntimos sobre el referidor (`User.referralRewardCents`).
model Referral {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrerUserId  String         @map("referrer_user_id") @db.Uuid
  referredUserId  String         @unique @map("referred_user_id") @db.Uuid
  /// Código de referido usado (snapshot del referralCode del referidor).
  code            String
  status          ReferralStatus @default(PENDING)
  /// Recompensa otorgada al referidor cuando se cumple la condición (céntimos PEN). 0 hasta otorgar.
  rewardCents     Int            @default(0) @map("reward_cents")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  rewardedAt      DateTime?      @map("rewarded_at") @db.Timestamptz

  @@index([referrerUserId])
  @@map("referrals")
  @@schema("identity")
}

/// Consentimientos Ley 29733 (APPEND-ONLY). Un row por cada evento de aceptación del pasajero.
/// Registro inmutable: NUNCA se actualiza ni se borra; cada cambio de preferencia es un row nuevo.
/// El estado vigente de un usuario es el row más reciente por `acceptedAt`.
model Consent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  /// Tratamiento de datos personales (base legal del servicio). Obligatorio para operar.
  dataProcessing Boolean  @map("data_processing")
  /// Cámara en vivo del habitáculo durante el viaje (diferenciador de seguridad).
  inCabinCamera  Boolean  @map("in_cabin_camera")
  /// Compartir ubicación con contactos de confianza / familia.
  location       Boolean
  /// Comunicaciones de marketing/promociones (opt-in, Ley 29733). Default false: nadie recibe promos sin aceptar.
  marketing      Boolean  @default(false)
  /// Versión de la política de privacidad aceptada (ej. "2026-05-01").
  policyVersion  String   @map("policy_version")
  /// Momento de la aceptación. Inmutable; ordena el historial.
  acceptedAt     DateTime @default(now()) @map("accepted_at") @db.Timestamptz
  /// IP de origen de la aceptación (evidencia de consentimiento). Null si no se pudo determinar.
  ip             String?
  /// Clave de idempotencia (UUIDv7) emitida por el cliente. UNIQUE → el doble submit es no-op (espeja
  /// PanicEvent.dedupKey). Nullable por backward-compat: los rows históricos / clientes sin dedupKey
  /// quedan en NULL (Postgres permite múltiples NULL en un UNIQUE → no rompe el append-only puro).
  dedupKey       String?  @unique @map("dedup_key")

  @@index([userId, acceptedAt])
  @@map("consents")
  @@schema("identity")
}

/// Outbox (FOUNDATION §6). Misma transacción que la mutación de dominio.
model OutboxEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregateId String    @map("aggregate_id")
  eventType   String    @map("event_type")
  envelope    Json
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  publishedAt DateTime? @map("published_at") @db.Timestamptz

  @@index([publishedAt, createdAt])
  @@map("outbox_events")
  @@schema("identity")
}

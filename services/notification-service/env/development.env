# notification-service · config DEV (tracked, SIN secretos). Los secretos (INTERNAL_IDENTITY_SECRET,
# APNs .p8, ruta del service-account JSON de FCM) viven en development.secret.env (gitignored), generado por
# dev-stack/boot-passenger-stack.sh. VEO_PUSH_MODE lo decide el boot: 'live' si está el JSON de FCM, si
# no 'sandbox' (degradación honesta: loguea el push en consola en vez de enviarlo).
NODE_ENV=development
PORT=3008
LOG_LEVEL=info

# Postgres compartido del dev-stack (contenedor veo-postgres, schema propio "notification").
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=notification

# Redis (locks del worker) + Kafka (outbox relay + consumidores de dominio) del dev-stack.
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9094

# Locale por defecto del dominio (Lima/Perú).
DEFAULT_LOCALE=es-PE

# ── PUSH (riel canónico FCM, FOUNDATION §0.7: transporte tras puerto propio) ──────────────────────
# La app registra token FCM para ambas plataformas; FCM HTTP v1 entrega iOS a APNs con la APNs key
# cargada en la consola de Firebase. FCM_PROJECT_ID es público (está en el GoogleService-Info.plist).
FCM_PROJECT_ID=veo-drive
# Riel de iOS: 'fcm' (default) o 'apns' (directo soberano; exige que la app registre el token APNs crudo).
PUSH_IOS_TRANSPORT=fcm
# Metadatos APNs (NO secretos): solo se usan si PUSH_IOS_TRANSPORT=apns. El .p8 (secreto) va en development.secret.env.
APNS_KEY_ID=TGZXNZ7CU8
APNS_TEAM_ID=2LG38U5XB4
APNS_BUNDLE_ID=pe.veo.passenger
# Host APNs directo: sandbox para builds Debug (development). Producción: https://api.push.apple.com
APNS_HOST=https://api.sandbox.push.apple.com

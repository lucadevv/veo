# notification-service · secretos DEV (PLANTILLA tracked). Copiar a `development.env` (GITIGNORED) y completar.
# El boot del passenger-stack (dev-stack/boot-passenger-stack.sh) genera el development.env real.
# VEO_PUSH_MODE lo decide el boot: 'live' si está el JSON de FCM, si no 'sandbox'.
#
# Metadatos PÚBLICOS (NO secretos, van en dev.env): FCM_PROJECT_ID, APNS_KEY_ID, APNS_TEAM_ID,
# APNS_BUNDLE_ID, APNS_HOST, PUSH_IOS_TRANSPORT. Acá solo van las CREDENCIALES.

# ── Identidad interna ──
# HMAC de identidad interna. DEBE ser IDÉNTICO en todos los services + los 3 BFFs (donde la var se
# llama VEO_INTERNAL_IDENTITY_SECRET). Si difiere entre dos, el guard interno rechaza la request.
INTERNAL_IDENTITY_SECRET=dev-internal-secret-change-me

# ── WEBHOOK (HMAC-SHA256) ──
# secret() → falla en prod si falta o sigue siendo el de dev. Firma el body de los webhooks salientes.
WEBHOOK_SIGNING_SECRET=dev-webhook-secret-change-me

# ── PUSH · FCM HTTP v1 (google-auth-library) — solo si VEO_PUSH_MODE=live ──
# Service account de Firebase. Dos formas EXCLUYENTES (usar una):
#  - GOOGLE_APPLICATION_CREDENTIALS: RUTA al JSON de la service account en disco.
#  - FCM_SERVICE_ACCOUNT_JSON: el JSON de la service account INLINE.
GOOGLE_APPLICATION_CREDENTIALS=
FCM_SERVICE_ACCOUNT_JSON=

# ── PUSH iOS · APNs HTTP/2 directo — solo si PUSH_IOS_TRANSPORT=apns ──
# Clave .p8 (PEM EC P-256) con la que se firma el JWT ES256 de APNs. Es la credencial soberana.
APNS_KEY_P8=

# ── SMS · selección de proveedor (OCP registry) ──
# SMS_PROVIDER manda si está definido: sandbox | smpp | twilio | whatsapp. Si se omite, se deriva del
# legado VEO_SMS_MODE (live→smpp, sandbox→sandbox). Default LOCAL = sandbox. (SMS_PROVIDER va en dev.env:
# es selección, no secreto.)

# ── SMS · SMPP 3.4 a operador — solo si SMS_PROVIDER=smpp (o VEO_SMS_MODE=live) ──
# Password del bind SMPP (system_id va en dev.env: SMPP_SYSTEM_ID es un identificador, no secreto).
SMPP_PASSWORD=

# ── SMS · Twilio REST — solo si SMS_PROVIDER=twilio ──
# AccountSid (AC…) y AuthToken son CREDENCIALES (secretas). From / MessagingServiceSid son
# identificadores → van en dev.env (TWILIO_FROM / TWILIO_MESSAGING_SERVICE_SID, definir uno u otro).
# En trial Twilio solo envía a números VERIFICADOS y asigna un From de trial.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── SMS · WhatsApp Cloud API (Meta Graph) — solo si SMS_PROVIDER=whatsapp ──
# PhoneNumberId y AccessToken son CREDENCIALES (secretas). El nombre del template, idioma y versión de
# Graph son metadatos públicos → dev.env (WHATSAPP_OTP_TEMPLATE / WHATSAPP_OTP_LANG / WHATSAPP_GRAPH_VERSION).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ── EMAIL · SMTP (nodemailer) — solo si VEO_EMAIL_MODE=live (dev usa Mailpit sin auth) ──
# Password del usuario SMTP (SMTP_USER va en dev.env: es un identificador, no secreto).
SMTP_PASS=

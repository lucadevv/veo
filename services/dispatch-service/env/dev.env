# dispatch-service · config DEV (tracked, SIN secretos). El INTERNAL_IDENTITY_SECRET vive en
# dev.secret.env (gitignored), generado por dev-stack/boot-passenger-stack.sh (sincronizado con bff/identity).
NODE_ENV=development
PORT=3003
LOG_LEVEL=info

# Postgres compartido del dev-stack (contenedor veo-postgres, schema propio del servicio).
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=dispatch

# Redis (hot index de ubicación + surge) + Kafka (outbox + consumidores).
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9094

# gRPC server (el bff apunta a DISPATCH_GRPC_URL=localhost:50053 por default) + cliente a identity.
GRPC_URL=0.0.0.0:50053
IDENTITY_GRPC_URL=localhost:50051

# Mapas: motor LOCAL determinista (ETA para el scoring del matching, sin OSRM en dev).
VEO_MAPS_MODE=local

// dispatch-service · esquema Postgres (schema lógico "dispatch")
// FOUNDATION §8. Dueño de: matching geoespacial (BR-T06), surge pricing y prioridad de pánico.
// El "hot index" de ubicación de conductores NO vive aquí: vive en Redis (baja latencia, TTL).
// Postgres guarda solo lo durable/auditable: ofertas (matches), zonas surge, proyección de stats y outbox.

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["dispatch"]
}

/// Resultado de una oferta de viaje a un conductor (BR-T06).
enum DispatchOutcome {
  OFFERED
  ACCEPTED
  REJECTED
  TIMEOUT

  @@schema("dispatch")
}

/// Tipo de vehículo requerido por el viaje (Ola 2B · tier moto-taxi). Espeja @veo/shared-types VehicleType.
enum VehicleType {
  CAR
  MOTO

  @@schema("dispatch")
}

/// Estado del matching SECUENCIAL (FIXED) de un viaje (process-manager DURABLE). Reemplaza el estado en
/// proceso (Map + Promise + timer) del matcher legacy: cualquier réplica avanza/cierra el matching leyendo
/// esta fila + las DispatchMatch del viaje. OPEN es el único no-terminal.
enum DispatchSessionStatus {
  OPEN /// negociando: hay (o va a haber) una oferta en vuelo
  MATCHED /// un conductor aceptó
  TIMED_OUT /// se agotaron los candidatos sin aceptación
  CANCELLED /// el viaje se canceló durante el matching

  @@schema("dispatch")
}

/// Cada oferta secuencial emitida durante el matching de un viaje. Auditable.
model DispatchMatch {
  id              String          @id @db.Uuid
  tripId          String          @map("trip_id") @db.Uuid
  driverId        String          @map("driver_id") @db.Uuid
  /// Score de ranking del algoritmo (BR-T06). Mayor = mejor candidato.
  score           Decimal         @db.Decimal(12, 6)
  /// Nº de oferta dentro del viaje (1 = primer candidato).
  attempt         Int
  /// Multiplier surge aplicado al momento de la oferta (1.0 = sin surge). Lo usa trip-service en la tarifa.
  surgeMultiplier Decimal         @default(1.0) @map("surge_multiplier") @db.Decimal(3, 2)
  outcome         DispatchOutcome @default(OFFERED)
  offeredAt       DateTime        @default(now()) @map("offered_at") @db.Timestamptz
  respondedAt     DateTime?       @map("responded_at") @db.Timestamptz

  @@index([tripId])
  @@index([driverId])
  @@index([tripId, outcome])
  /// Hot-path del reconciler (sweepExpiredOffers, @Interval ~0.5Hz): filtra outcome=OFFERED (igualdad)
  /// + offeredAt < cutoff (rango) y ordena por offeredAt. outcome primero (igualdad), offeredAt segundo (rango+orden).
  @@index([outcome, offeredAt])
  @@map("dispatch_matches")
  @@schema("dispatch")
}

/// Sesión de matching secuencial de UN viaje (FIXED dispatch mode). Una por viaje (trip_id @id). Guarda
/// lo que el "advance" (offerNext) necesita para ofertar al SIGUIENTE candidato desde cualquier réplica
/// (sin el evento original): origen, tipo de vehículo y el k-ring actual. El set de "ya ofertados" NO se
/// duplica acá: son las filas DispatchMatch del viaje. Los cierres (MATCHED/TIMED_OUT/CANCELLED) son CAS
/// atómicos (updateMany con guard de status) → idempotentes y concurrencia-seguros.
model DispatchSession {
  tripId       String                @id @map("trip_id") @db.Uuid
  status       DispatchSessionStatus @default(OPEN)
  originLat    Float                 @map("origin_lat")
  originLon    Float                 @map("origin_lon")
  /// El advance re-rankea SOLO conductores de este tipo (un viaje MOTO no se ofrece a un CAR).
  vehicleType  VehicleType           @default(CAR) @map("vehicle_type")
  /// k-ring actual de la búsqueda (1..maxKRing): el advance expande cuando se agotan los cercanos.
  currentKRing Int                   @default(1) @map("current_k_ring")
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  /// El reconciler/limpieza lista las sesiones OPEN; los cierres consultan por status.
  @@index([status])
  @@map("dispatch_sessions")
  @@schema("dispatch")
}

/// Zona de surge: conjunto de celdas H3 (o bbox) donde el precio sube si demanda/oferta supera el umbral.
model SurgeZone {
  id                    String   @id @db.Uuid
  name                  String
  /// Celdas H3 (res 9) que componen la zona. Membresía exacta por celda.
  cells                 Json     @default("[]")
  /// Bounding box alternativo/complementario (cuando no se enumeran celdas).
  minLat                Float?   @map("min_lat")
  maxLat                Float?   @map("max_lat")
  minLon                Float?   @map("min_lon")
  maxLon                Float?   @map("max_lon")
  /// Umbral demanda/oferta a partir del cual se activa el multiplier.
  demandSupplyThreshold Decimal  @map("demand_supply_threshold") @db.Decimal(6, 2)
  /// Multiplier aplicado cuando se supera el umbral (1.2 – 2.0).
  multiplier            Decimal  @db.Decimal(3, 2)
  active                Boolean  @default(true)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([active])
  @@map("surge_zones")
  @@schema("dispatch")
}

/// Proyección local de métricas del conductor para el scoring (BR-T06).
/// Decisión: poblada por eventos (rating.created / driver.flagged / trip.completed / trip.cancelled),
/// NUNCA por join cross-servicio. Evita acoplar dispatch a la BD de identity/rating y mantiene baja latencia.
model DriverStats {
  driverId       String    @id @map("driver_id") @db.Uuid
  /// Rating promedio (1..5). Se actualiza con rating.created (media móvil) o driver.flagged (valor directo).
  avgRating      Decimal   @default(5.0) @map("avg_rating") @db.Decimal(3, 2)
  ratingCount    Int       @default(0) @map("rating_count")
  completedTrips Int       @default(0) @map("completed_trips")
  cancelledTrips Int       @default(0) @map("cancelled_trips")
  /// Último viaje completado (para el término de inactividad del score).
  lastTripAt     DateTime? @map("last_trip_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("driver_stats")
  @@schema("dispatch")
}

/// Config SINGLETON de RADIOS de dispatch (k-rings) editable en runtime por el admin (espejo del
/// pricing_mode_schedule del trip-service). UNA sola fila (id='GLOBAL', Tier 1): `nearbyKRing` = radio
/// del feed de mapa de "autos cerca"; `matchKRing` = radio de broadcast de pujas/matching. El `version`
/// se bumpea en cada PUT (auditable + dedupe del evento dispatch.radius_config_updated). Sin fila → el
/// service degrada al DEFAULT_RADIUS_CONFIG explícito (version 0), no crash.
model DispatchRadiusConfig {
  id          String   @id
  /// k-ring del feed de mapa (NearbyDriversService): cuántos anillos H3 alrededor del origen se muestrean.
  nearbyKRing Int      @map("nearby_k_ring")
  /// k-ring del broadcast de pujas / matching (OfferBoardService): radio de candidatos elegibles.
  matchKRing  Int      @map("match_k_ring")
  version     Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("dispatch_radius_config")
  @@schema("dispatch")
}

/// Outbox (FOUNDATION §6). Insertado en la MISMA transacción que la mutación de dominio.
model OutboxEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregateId String    @map("aggregate_id")
  eventType   String    @map("event_type")
  envelope    Json
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  publishedAt DateTime? @map("published_at") @db.Timestamptz

  @@index([publishedAt, createdAt])
  @@map("outbox_events")
  @@schema("dispatch")
}

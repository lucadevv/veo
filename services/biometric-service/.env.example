# biometric-service (Python/FastAPI · pydantic-settings) · PLANTILLA de entorno (tracked).
# Copiar a `.env` (GITIGNORED) y ajustar. pydantic Settings ya lee `.env` con env_prefix=VEO_BIO_
# (ver app/config.py · SettingsConfigDict). Por eso seguimos la convención de pydantic (`.env.example`)
# y NO el patrón env/dev.env de los services NestJS: el código ya espera `.env`.
#
# SECRETOS: este service NO maneja NINGÚN secreto. Los modelos ONNX son self-hosted (det_10g/w600k,
# descargados con scripts/download_models.py) y onnxruntime corre 100% local — sin API keys ni
# provider creds. Por eso NO existe un `.env.example`: no hay nada secreto que templar.
# Todas las VEO_BIO_* de abajo son config PÚBLICA (modelo, umbrales, observabilidad).
#
# Todos los valores listados son los DEFAULTS del código (app/config.py); ajustá solo lo que difiera.

# --- HTTP ---
VEO_BIO_HOST=0.0.0.0
# Puerto canonico de biometric-service: 3015 (siguiente libre tras chat=3014). places-service
# conserva 3013 (ya implementado y corriendo en dev-stack/gRPC 50063). Ver docs/FOUNDATION.md.
VEO_BIO_PORT=3015
VEO_BIO_SERVICE_NAME=biometric-service

# --- Modelos ONNX (self-hosted, sin creds) ---
VEO_BIO_MODEL_DIR=models
# buffalo_l: detector SCRFD-10G (det_10g.onnx) + recognizer ArcFace (w600k_r50.onnx).
VEO_BIO_DETECTOR_MODEL=det_10g.onnx
VEO_BIO_EMBEDDER_MODEL=w600k_r50.onnx
# Proveedores onnxruntime en orden de preferencia (CSV/tupla). CPU-only por defecto.
VEO_BIO_ONNX_PROVIDERS=CPUExecutionProvider
# True => /verify falla si faltan los modelos. False => /verify devuelve 503 (degradado) pero el service arranca.
VEO_BIO_REQUIRE_MODELS=false

# --- Detección ---
VEO_BIO_DETECTION_SIZE=640
VEO_BIO_DETECTION_THRESHOLD=0.5
# Tamaño mínimo (px) del rostro detectado para considerarlo "claro".
VEO_BIO_MIN_FACE_SIZE=80

# --- Matching (BR-I02: umbral 0.90) — rango [0.0, 1.0] ---
VEO_BIO_MATCH_THRESHOLD=0.90

# --- Liveness activo (por reto) ---
VEO_BIO_CHALLENGE_TTL_SECONDS=60
VEO_BIO_MIN_FRAMES_FOR_LIVENESS=3
# Umbrales geométricos (grados / ratios normalizados por distancia interocular).
VEO_BIO_YAW_TURN_DEGREES=18.0
VEO_BIO_PITCH_NOD_DEGREES=12.0
VEO_BIO_BLINK_EAR_THRESHOLD=0.21
VEO_BIO_EYE_OPEN_EAR_THRESHOLD=0.28
VEO_BIO_SMILE_RATIO_THRESHOLD=1.45
VEO_BIO_MOUTH_OPEN_RATIO_THRESHOLD=0.35
# Retos disponibles (CSV/tupla). BLINK/OPEN_MOUTH requieren landmarks densos (ver README).
VEO_BIO_LIVENESS_ACTIONS=TURN_LEFT,TURN_RIGHT,NOD,SMILE
# Escalas de calibración pose (grados por unidad de ratio normalizado interocular).
VEO_BIO_YAW_SCALE_DEG=90.0
VEO_BIO_PITCH_SCALE_DEG=70.0

# --- Observabilidad ---
VEO_BIO_OTEL_ENABLED=false
# Vacío = exportador OTLP deshabilitado. El dev-stack expone OTLP HTTP en :4318.
VEO_BIO_OTEL_EXPORTER_OTLP_ENDPOINT=
# Uno de: DEBUG | INFO | WARNING | ERROR
VEO_BIO_LOG_LEVEL=INFO

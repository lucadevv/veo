# payment-service · config DEV (tracked, SIN secretos). El INTERNAL_IDENTITY_SECRET vive en
# dev.secret.env (gitignored), generado por dev-stack/boot-passenger-stack.sh (sincronizado con bff/identity).
NODE_ENV=development
PORT=3005
LOG_LEVEL=info

# Postgres compartido del dev-stack (contenedor veo-postgres, schema propio del servicio).
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=payment

# Redis + Kafka del dev-stack.
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9094

# Riel Yape/Plin tras el puerto PaymentGateway: ProntoPaga contra su SANDBOX REAL (Yape/Plin/tarjeta/PagoEfectivo PE).
# A producción solo cambian las credenciales en dev.secret.env (gitignored). Para sandbox determinista in-process: =sandbox.
VEO_PAYMENT_MODE=prontopaga
# Agregador ProntoPaga (config NO secreta; las credenciales públicas de prueba viven en dev.secret.env).
PRONTOPAGA_BASE_URL=https://sandbox.prontopaga.com
# Base PÚBLICA para armar urlConfirmation/urlFinal/urlRejected del webhook.
# CRÍTICO (payments/prontopaga-cloudflare-fix): el WAF de Cloudflare delante de ProntoPaga BLOQUEA
# (403 "Attention Required", regla SSRF/SQLi) cualquier POST /api/payment/new cuyo urlConfirmation
# apunte a localhost/127.0.0.1. NO es bot-challenge ni huella TLS — curl/undici/fetch fallan IGUAL con
# localhost y PASAN con una URL pública. En dev usamos un dominio público (el webhook NO llega a la
# laptop; el poll fallback GET /api/payment/data/{uid} resuelve la captura). En prod = URL real del webhook.
PRONTOPAGA_WEBHOOK_BASE_URL=https://payments-dev.veo.pe

# gRPC server (lecturas síncronas desde el BFF; el bff apunta a PAYMENT_GRPC_URL=localhost:50055 por default).
GRPC_URL=0.0.0.0:50055

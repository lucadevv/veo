// payment-service · esquema Postgres (schema lógico "payment")
// FOUNDATION §8. Dueño de: cobros (Yape/Plin/efectivo/tarjeta), comisión de plataforma,
// payouts a conductores, reembolsos, confirmaciones de efectivo y conciliación de extractos.
// El dinero SIEMPRE en céntimos PEN (enteros). UUIDv7 generado en el dominio (no en DB).

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["payment"]
}

enum PaymentMethod {
  YAPE
  PLIN
  CASH
  CARD
  PAGOEFECTIVO

  @@schema("payment")
}

/// Estado de una afiliación de wallet (Yape On File · ProntoPaga).
///  PROCESS → creada, esperando que el cliente apruebe en su app (deepLink). 15 min de ventana.
///  ACTIVE  → confirmada por webhook; habilita el cobro on-file (yape_cof_payment + walletUid).
///  EXPIRED → el cliente no aprobó a tiempo (webhook expired).
///  REVOKED → baja local (el cliente o soporte la dieron de baja). No se vuelve a usar para cobrar.
enum AffiliationStatus {
  PROCESS
  ACTIVE
  EXPIRED
  REVOKED

  @@schema("payment")
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DEBT

  @@schema("payment")
}

/// MODO del cobro (F2.7 · ADR-017 §1.6 / ADR-015 §11.2 · nudo legal). Determina el MODELO de dinero:
///  ON_DEMAND  → comisión DESCONTADA al conductor; tasa CONFIGURABLE por el admin (CommissionConfig.onDemandRateBps).
///  CARPOOLING → service fee SUMADO al pasajero (CommissionConfig.carpoolingFeeBps); el conductor cobra el 100%
///               del cost-sharing. Admin-editable, ARRANCA EN 0 (sin lucro hasta visto bueno legal) y el admin
///               lo sube. NO se descuenta al conductor (a diferencia de ON_DEMAND). Ver ADR-017 §1.6.
/// La columna Payment.mode es NULLABLE: las filas legacy (pre-F2.7) se LEEN como ON_DEMAND (su comportamiento
/// histórico: comisión global de env). El modo se determina en el PUNTO DE ENTRADA del cobro, NO en los
/// contratos de eventos cross-service.
enum PaymentMode {
  ON_DEMAND
  CARPOOLING

  @@schema("payment")
}

/// A1 (ADR-022) · CLASE del cobro. Discriminador TIPADO (jamás inferir por gross=0): distingue el cobro de
/// TARIFA del cobro dedicado de PROPINA digital, para que los lookups by-trip de la tarifa (refund, recibo)
/// NO confundan el uno con el otro.
///  - FARE: cobro de la tarifa del viaje (default → todas las filas legacy quedan FARE, cero cambio al desplegar).
///  - TIP:  cobro dedicado de una propina DIGITAL (gross 0, comisión 0, 100% al conductor). Solo la propina
///          digital es un Payment; la propina en EFECTIVO se registra como TipAddition "en mano" (sin cobro).
enum PaymentKind {
  FARE
  TIP

  @@schema("payment")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PROCESSED
  HELD
  FAILED

  @@schema("payment")
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED

  @@schema("payment")
}

/// Estado de una penalidad de cancelación (F2 · BR-T03).
///  PENDING   → registrada, el pasajero la debe (bloquea nuevos viajes vía el gate).
///  COLLECTED → saldada; la compensación del conductor entra a su payout.
///  WAIVED    → perdonada por soporte (no se cobra).
enum CancellationPenaltyStatus {
  PENDING
  COLLECTED
  WAIVED

  @@schema("payment")
}

/// Penalidad por cancelación del PASAJERO (F2). trip-service calcula `penaltyCents` y lo emite en
/// `trip.cancelled`; payment-service lo registra acá como obligación cobrable, con el split
/// conductor/plataforma. Idempotente por `tripId` (UNIQUE): un evento reprocesado no duplica.
model CancellationPenalty {
  id                      String                    @id @db.Uuid
  tripId                  String                    @unique @map("trip_id") @db.Uuid
  passengerId             String                    @map("passenger_id") @db.Uuid
  driverId                String?                   @map("driver_id") @db.Uuid
  penaltyCents            Int                       @map("penalty_cents")
  /// Compensación al conductor que esperó (parte del split). Entra a su payout al saldarse.
  driverCompensationCents Int                       @map("driver_compensation_cents")
  /// Parte de la plataforma (penaltyCents − driverCompensationCents).
  platformCents           Int                       @map("platform_cents")
  status                  CancellationPenaltyStatus @default(PENDING)
  reason                  String?
  createdAt               DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  collectedAt             DateTime?                 @map("collected_at") @db.Timestamptz

  @@index([passengerId, status])
  // Cron semanal de payouts: collectEarnings filtra status=COLLECTED + rango collectedAt para el split del conductor.
  @@index([status, collectedAt])
  @@map("cancellation_penalties")
  @@schema("payment")
}

/// Tipo de descuento de una promoción (Ola 2A).
enum PromoKind {
  PERCENTAGE // descuento porcentual sobre el bruto
  FIXED // monto fijo de descuento en céntimos PEN

  @@schema("payment")
}

/// Cobro de un viaje (BR-P01..P04). Idempotente por `dedupKey` (UNIQUE).
/// grossCents = ticket bruto (incluye surge, EXCLUYE propinas) → base de la comisión (BR-P04).
/// tipCents   = propina (100% al conductor, fuera de comisión).
/// amountCents = total cobrado al pasajero = grossCents + tipCents.
/// commissionCents = commission(grossCents, rate). feeCents = comisión visible al usuario.
model Payment {
  id              String        @id @db.Uuid
  tripId          String        @map("trip_id") @db.Uuid
  /// Conductor del viaje (para agregación de payouts). Puede faltar si el cobro nace del evento.
  driverId        String?       @map("driver_id") @db.Uuid
  /// Pasajero del viaje (lo trae el trip.completed que dispara el cobro). Se persiste para enriquecer
  /// payment.captured / payment.refunded y que notification-service mande el push al pasajero
  /// ("pago confirmado" / "te devolvimos") sin un join cross-servicio. Opcional (cobros legacy/sin id).
  passengerId     String?       @map("passenger_id") @db.Uuid
  /// Clave de idempotencia (UUIDv7 o derivada determinista del viaje). UNIQUE.
  dedupKey        String        @unique @map("dedup_key")
  amountCents     Int           @map("amount_cents")
  grossCents      Int           @map("gross_cents")
  /// Descuento de promoción aplicado al pasajero (céntimos). 0 si no hubo promo (Ola 2A).
  /// amountCents = grossCents − discountCents − creditCents + tipCents. La comisión se calcula SOBRE
  /// grossCents (la plataforma asume el costo de promo + crédito); la propina queda intacta.
  discountCents   Int           @default(0) @map("discount_cents")
  /// Crédito de referido GASTADO en este cobro (céntimos · Ola 2A · Lote B). Separado de discountCents
  /// para reconciliación: promo = campaña de marketing, crédito = saldo ganado por el usuario (pasivos
  /// distintos). Decrementa `UserCredit.balanceCents` en spendForCharge (idempotente por `credit:dedupKey`).
  creditCents     Int           @default(0) @map("credit_cents")
  tipCents        Int           @default(0) @map("tip_cents")
  commissionCents Int           @map("commission_cents")
  feeCents        Int           @map("fee_cents")
  /// P-B (ADR-022) · Fee del PSP (ProntoPaga) que se DESCUENTA antes de que la plata llegue al banco de la
  /// plataforma. Se MODELA en la captura desde `CommissionConfig.<método>FeeBps` (editable por admin). CASH = 0
  /// (el efectivo no pasa por el PSP). NULL = cobro legacy pre-P-B (fee no modelado → degradación honesta).
  pspFeeCents     Int?          @map("psp_fee_cents")
  /// P-B · Neto REAL que la plataforma recibe en el banco = amountCents − pspFeeCents. Es el "money-in real"
  /// (los KPIs/conciliación usan ESTO, no el bruto). NULL = legacy (cae a amountCents en la degradación honesta).
  netSettledCents Int?          @map("net_settled_cents")
  /// Acumulado reembolsado (céntimos) sobre amountCents (BR-P06). 0 = sin reembolso. Permite refunds
  /// PARCIALES: status=PARTIALLY_REFUNDED mientras refundedCents < amountCents, REFUNDED al completarse.
  refundedCents   Int           @default(0) @map("refunded_cents")
  currency        String        @default("PEN")
  method          PaymentMethod
  /// Referencia externa del riel de pago (id de transacción Yape/Plin). Null hasta confirmar.
  externalRef     String?       @map("external_ref")
  status          PaymentStatus @default(PENDING)
  /// MODO del cobro (F2.7): determina el MODELO de dinero (ON_DEMAND = comisión al conductor, configurable ·
  /// CARPOOLING = service fee al pasajero, editable, arranca en 0). NULLABLE para compat con filas legacy
  /// (pre-F2.7), que se LEEN como ON_DEMAND. Se setea en el punto de entrada del cobro (consumer trip.completed
  /// → ON_DEMAND; charge service-rail → CARPOOLING).
  mode            PaymentMode?  @default(ON_DEMAND)
  /// Intentos consumidos contra el gateway (BR-P02: máx 3 antes de DEBT).
  retries         Int           @default(0)
  /// Última razón de fallo (para soporte/observabilidad).
  failureReason   String?       @map("failure_reason")
  /// Referencia del pagador en el riel (teléfono/token Yape-Plin). PII mínima.
  payerRef        String?       @map("payer_ref")
  /// A1 (ADR-022) · Clase del cobro (FARE tarifa | TIP propina digital dedicada). Ver `enum PaymentKind`.
  /// Los lookups by-trip de la TARIFA (refund, recibo) filtran `kind = FARE` para no agarrar un cobro de propina.
  kind            PaymentKind   @default(FARE)
  /// F2.3 · Si este Payment SALDA una penalidad de cancelación, su id (sino null). Un Payment de
  /// liquidación lleva `driverId=NULL` (no es ganancia de viaje → no entra al payout por aquí; la
  /// compensación del conductor entra vía `collectEarnings` sumando la penalidad COLLECTED). Al
  /// capturarse, `captureSuccess` flippea la penalidad → COLLECTED en la misma transacción.
  cancellationPenaltyId String? @map("cancellation_penalty_id") @db.Uuid
  /// ── Checkout externo (ProntoPaga PENDING_EXTERNAL) ── El cobro quedó pendiente y el pasajero lo
  /// completa FUERA (QR/deepLink/CIP) o el on-file confirma por webhook. El recibo (L2 by-trip) los expone.
  /// uid de la transacción en ProntoPaga (correlación con el webhook). Distinto de externalRef hasta capturar.
  externalUid     String?       @map("external_uid")
  /// URL hospedada del proveedor para completar el pago (tarjeta/QR web).
  checkoutUrl     String?       @map("checkout_url")
  /// QR como data-URI PNG base64 para pintar en la app (Yape/Plin QR).
  qrCode          String?       @map("qr_code")
  /// Deep-link para abrir la app del wallet (Yape one-shot).
  deepLink        String?       @map("deep_link")
  /// Código CIP de PagoEfectivo (pago en agente/efectivo).
  cip             String?       @map("cip")
  /// Caducidad del checkout (si el proveedor la informa).
  checkoutExpiresAt DateTime?   @map("checkout_expires_at") @db.Timestamptz
  capturedAt      DateTime?     @map("captured_at") @db.Timestamptz
  refundedAt      DateTime?     @map("refunded_at") @db.Timestamptz
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  refunds Refund[]
  tips    TipAddition[]

  @@index([status])
  @@index([tripId])
  // [driverId, status, capturedAt]: earningsForDriver filtra driverId+status y RANGO capturedAt (el antiguo
  // [driverId, status] no empujaba el rango). El 3-col subsume al 2-col (mismo prefijo) → reemplaza, no duplica.
  @@index([driverId, status, capturedAt])
  @@index([method, status, capturedAt])
  // Polls por antigüedad: payment-poll (status=PENDING + createdAt range/order) y los sweeps de reconciliación.
  @@index([status, createdAt])
  // Fallback del webhook de cobro sin paymentId: correlaciona por externalUid (findFirst).
  @@index([externalUid])
  /// F2.3 · resolver el Payment de liquidación de una penalidad (idempotencia/conciliación).
  @@index([cancellationPenaltyId])
  /// DEBT gate: lista la deuda PENDIENTE de un pasajero (status=DEBT) en O(log n) sin escanear.
  /// Sirve a GET /payments/debt (bloqueo de nuevos viajes) por [passengerId, status].
  @@index([passengerId, status])
  @@map("payments")
  @@schema("payment")
}

/// Comisión de plataforma por MODO, editable en caliente (F2.7 · ADR-017 §1.6 / ADR-015 §11.2). SINGLETON
/// (espejo de base_fare_config de trip-service): un solo registro GLOBAL con DOS tasas, ambas configurables:
/// la comisión ON-DEMAND (descontada al conductor) y el service fee CARPOOLING (sumado al pasajero en
/// cost-sharing — el conductor cobra el 100% de su contribución). Las tasas van en BASIS POINTS Int
/// (0..10000; 2000 = 20%) — NUNCA float persistido. `version` = optimistic locking (CAS) en el reemplazo.
model CommissionConfig {
  id               String   @id
  /// Tasa de comisión ON-DEMAND en basis points (0..10000; 2000 = 20%). Se divide /10000 al APLICAR
  /// (redondeo a céntimo Int en la fórmula commission()); jamás se persiste ni se opera como float.
  onDemandRateBps  Int      @default(2000) @map("on_demand_rate_bps")
  /// Service fee CARPOOLING en basis points (0..10000). Arranca en 0; el admin lo sube. Se SUMA al pasajero
  /// (no se descuenta al conductor). Mismo tratamiento Int/redondeo que la comisión on-demand.
  carpoolingFeeBps Int      @default(0) @map("carpooling_fee_bps")
  /// P-B (ADR-022) · Fee del PSP (ProntoPaga) por MÉTODO digital, en basis points Int (0..10000). EDITABLE por
  /// admin (arranca en 0 = degradación honesta hasta que el dueño cargue las tarifas del convenio). El fee varía
  /// por método (los SLAs de ProntoPaga son por método/país). CASH no tiene fee (no pasa por el PSP). Se descuenta
  /// del bruto en la captura para computar el neto REAL que llega al banco (`Payment.netSettledCents`).
  yapeFeeBps         Int    @default(0) @map("yape_fee_bps")
  plinFeeBps         Int    @default(0) @map("plin_fee_bps")
  cardFeeBps         Int    @default(0) @map("card_fee_bps")
  pagoefectivoFeeBps Int    @default(0) @map("pagoefectivo_fee_bps")
  /// CAS de la comisión ON-DEMAND + los fees PSP (yape/plin/card/pagoefectivo). El PUT de on-demand y el de
  /// PSP fees bumpean ESTA version. NO la toca el PUT del service fee de carpooling (que tiene su propia CAS).
  version          Int      @default(0)
  /// CAS INDEPENDIENTE del service fee de CARPOOLING (`carpoolingFeeBps`). El PUT de carpooling bumpea SOLO esta
  /// version → editar el carpooling y editar la comisión on-demand ya NO se 409ean entre sí (cada panel su CAS).
  carpoolingFeeVersion Int  @default(0) @map("carpooling_fee_version")
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("commission_config")
  @@schema("payment")
}

/// Liquidación semanal por conductor (BR-P05). amountCents = neto a pagar (gross - comisión + propinas).
model Payout {
  id              String       @id @db.Uuid
  driverId        String       @map("driver_id") @db.Uuid
  periodStart     DateTime     @map("period_start") @db.Timestamptz
  periodEnd       DateTime     @map("period_end") @db.Timestamptz
  grossCents      Int          @map("gross_cents")
  commissionCents Int          @map("commission_cents")
  amountCents     Int          @map("amount_cents")
  /// A2 (ADR-022) · Deuda CASH del conductor NETEADA en este payout (comisión de viajes en efectivo que él
  /// cobró en mano). `amountCents = ganancia digital − debtAppliedCents`. 0 si el conductor no tenía deuda.
  /// Auditoría del flujo inverso: cuánto le descontamos por la comisión que recaudó en efectivo.
  debtAppliedCents Int         @default(0) @map("debt_applied_cents")
  currency        String       @default("PEN")
  status          PayoutStatus @default(PENDING)
  processedAt     DateTime?    @map("processed_at") @db.Timestamptz
  /// Motivo de retención si el conductor está en review (BR-P05, evento driver.flagged).
  heldReason      String?      @map("held_reason")
  /// ADR-015 §7 · Idempotencia financiera del DESEMBOLSO money-OUT: `dedupKey = payout-disburse:{payoutId}`,
  /// derivada del payoutId, distinta del `booking-charge:{bookingId}` del CHARGE para no colisionar. Reintentos
  /// del mismo payout (FAILED→PROCESSING) → la misma key → el riel NO duplica la transferencia. Nullable y additive:
  /// los payouts existentes (pre-desembolso-real) quedan con dedupKey = NULL hasta que el operador los dispare.
  dedupKey        String?      @unique @map("dedup_key")
  /// ADR-015 §2 · Ref de la transferencia en el riel de desembolso (uid externo del PayoutGateway). Correlaciona
  /// el webhook/poll de confirmación (PROCESSING→PROCESSED|FAILED). Null hasta que el desembolso se dispara.
  externalRef     String?      @map("external_ref")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  /// Un payout por conductor y período (idempotencia del cron semanal).
  @@unique([driverId, periodStart, periodEnd])
  @@index([status])
  // payout-poll: status=PROCESSING ordenado por updatedAt (el crash-recovery/reconciliación de desembolsos).
  @@index([status, updatedAt])
  @@map("payouts")
  @@schema("payment")
}

/// A2 (ADR-022) · Motivo de una deuda del conductor con la plataforma. Union TIPADA (cero strings mágicos).
enum DriverDebtReason {
  /// El conductor cobró la comisión EN EFECTIVO (viaje CASH) → la debe a la plataforma.
  CASH_COMMISSION

  @@schema("payment")
}

/// A2 · Estado de una deuda del conductor. PENDING = por netear del payout digital; SETTLED = ya descontada de un
/// payout; REVERSED = anulada porque el viaje CASH se reembolsó/canceló (el conductor ya no debe esa comisión).
enum DriverDebtStatus {
  PENDING
  SETTLED
  REVERSED

  @@schema("payment")
}

/// A2 (ADR-022 §P-A) · Ledger de DEUDAS del conductor con la plataforma (el flujo INVERSO del dinero: la plata va
/// del conductor a la plataforma). Nace cuando el conductor cobra la comisión EN MANO (viaje CASH): la plataforma
/// no la recaudó → el conductor la DEBE. Se NETEA contra su payout DIGITAL (liquidación semanal); si la deuda
/// supera el digital, el resto queda PENDING (carry-forward al próximo período). Modelado explícito, no un signo.
model DriverDebt {
  id          String           @id @db.Uuid
  driverId    String           @map("driver_id") @db.Uuid
  tripId      String           @map("trip_id") @db.Uuid
  /// El cobro CASH que originó la deuda. UNIQUE → idempotencia: una deuda por cobro (la captura no la duplica).
  paymentId   String           @unique @map("payment_id") @db.Uuid
  /// Monto adeudado = la comisión del viaje (lo que el conductor cobró en mano y le corresponde a la plataforma).
  amountCents Int              @map("amount_cents")
  currency    String           @default("PEN")
  reason      DriverDebtReason @default(CASH_COMMISSION)
  status      DriverDebtStatus @default(PENDING)
  /// El Payout donde esta deuda se NETEÓ (SETTLED). Null mientras PENDING. Para conciliación/auditoría.
  settledInPayoutId String?    @map("settled_in_payout_id") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  settledAt   DateTime?        @map("settled_at") @db.Timestamptz

  /// Netting: enumerar la deuda PENDIENTE de un conductor en el run de payouts (O(log n)).
  @@index([driverId, status])
  @@map("driver_debts")
  @@schema("payment")
}

/// Crédito A FAVOR del conductor: la plataforma se lo debe (el inverso de DriverDebt). Hoy solo lo origina el
/// reverso de una comisión CASH cuya deuda YA se neteó en un payout (SETTLED): al revertir el viaje, el conductor
/// pagó una comisión que ya no debía → se le acredita y se SUMA al neto del próximo payout (applyDebtNetting).
/// Modelo separado a propósito (no un DriverDebt con monto negativo): preserva el contrato `DriverDebt.paymentId
/// @unique` y mantiene una responsabilidad por tabla (deuda vs crédito).
model DriverCredit {
  id          String             @id @db.Uuid
  driverId    String             @map("driver_id") @db.Uuid
  tripId      String             @map("trip_id") @db.Uuid
  /// A favor del conductor, en céntimos (>0).
  amountCents Int                @map("amount_cents")
  currency    String             @default("PEN")
  /// El cobro CASH cuyo reverso originó el crédito. UNIQUE → idempotencia: un crédito por reverso de cobro (un
  /// refund re-entregado NO duplica el crédito).
  sourcePaymentId String         @unique @map("source_payment_id") @db.Uuid
  status      DriverCreditStatus @default(PENDING)
  /// El Payout donde el crédito se APLICÓ (sumado al neto). Null mientras PENDING. Para conciliación/auditoría.
  appliedInPayoutId String?      @map("applied_in_payout_id") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz
  appliedAt   DateTime?          @map("applied_at") @db.Timestamptz

  /// Netting: enumerar el crédito PENDIENTE de un conductor en el run de payouts (O(log n)).
  @@index([driverId, status])
  @@map("driver_credits")
  @@schema("payment")
}

enum DriverCreditStatus {
  PENDING
  APPLIED

  @@schema("payment")
}

/// Solicitud de reembolso (BR-P06): ventana 7 días, aprobación manual L1/L2 (>S/30 requiere L2).
/// S5 · Reembolso REAL contra el proveedor: el Refund digital nace PENDING (intent persistido ANTES de
/// llamar al riel, §4 idempotencia) y SOLO pasa a COMPLETED cuando el proveedor confirma el reverso
/// (síncrono o por callback) — recién ahí se emite payment.refunded (push "te devolvimos S/X").
model Refund {
  id          String       @id @db.Uuid
  paymentId   String       @map("payment_id") @db.Uuid
  payment     Payment      @relation(fields: [paymentId], references: [id])
  amountCents Int          @map("amount_cents")
  requestedBy String       @map("requested_by")
  approvedBy  String?      @map("approved_by")
  status      RefundStatus @default(PENDING)
  reason      String
  /// UID del reverso en el proveedor (ProntoPaga /reverse/new → uid). Correlaciona el callback
  /// asíncrono (urlCallbackRefund). Null si el reverso fue local (CASH) o el proveedor no lo emitió.
  externalRefundId String? @map("external_refund_id")
  /// Motivo del RECHAZO del proveedor (status=REJECTED). Distinto de `reason` (motivo del pedido).
  failureReason String?    @map("failure_reason")
  /// F3c-payment · Clave de idempotencia DETERMINISTA de un refund SYSTEM-INITIATED (refund automático por
  /// `booking.cancelled`). Derivada del bookingId (`booking-cancel-refund:{bookingId}`), espeja el patrón de
  /// `TipAddition.dedupKey` y `Payment.dedupKey` (cobro). NULL en los refunds ADMIN discrecionales (esos llevan
  /// operador humano y su idempotencia es el CAS optimista del Payment).
  ///
  /// ⚠️ UNICIDAD = ÍNDICE PARCIAL en SQL (Prisma NO lo modela): el UNIQUE corre SOLO sobre los refunds ACTIVOS
  /// (status <> REJECTED). Un refund REJECTED por el proveedor NO participa del UNIQUE → el reintento legítimo
  /// del MISMO `booking.cancelled` puede crear un Refund NUEVO (la plata se devuelve aunque el 1er reverso
  /// fallara), mientras un PENDING/COMPLETED SÍ bloquea (no doble-refund). Un `@unique` GLOBAL acá envenenaría
  /// la key: tras un SOLO rechazo del proveedor el reintento chocaría P2002 → `skipped` → el pasajero NUNCA
  /// recibiría su plata (refund-starvation, viola ADR-014 §6 "refund OBLIGATORIO"). El índice parcial vive en
  /// la migración `20260622000000_refund_dedup_key` (`WHERE status <> 'REJECTED' AND dedup_key IS NOT NULL`) —
  /// NO lo "corrijas" a `@unique` ni dejes que un `prisma migrate` lo regenere como total: rompés el reintento.
  dedupKey      String?    @map("dedup_key")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  @@index([paymentId])
  @@index([status])
  // Barrido horario de refunds PENDING viejos (sweepStalePendingRefunds): status=PENDING + createdAt range/order.
  @@index([status, createdAt])
  /// Correlación del callback de reembolso del proveedor (uid → Refund).
  @@index([externalRefundId])
  /// El UNIQUE de `dedupKey` es PARCIAL (status <> REJECTED) y vive SOLO en SQL (ver comentario del campo); acá
  /// un índice NO-único para correlacionar el dedupKey al booking en el backstop admin de refunds REJECTED
  /// (marcador durable + métrica + alerta; el cron re-conductor automático fue ELIMINADO por frágil).
  @@index([dedupKey])
  @@map("refunds")
  @@schema("payment")
}

/// Propina añadida a un viaje ya cobrado (BR-P04: 100% al conductor, fuera de comisión).
/// Idempotente por `dedupKey` (UNIQUE): reenviar la misma propina no la vuelve a sumar.
/// Cada fila es un incremento atómico de `payment.tipCents` y `payment.amountCents`.
model TipAddition {
  id        String   @id @db.Uuid
  paymentId String   @map("payment_id") @db.Uuid
  payment   Payment  @relation(fields: [paymentId], references: [id])
  tripId    String   @map("trip_id") @db.Uuid
  /// Clave de idempotencia del incremento. UNIQUE.
  dedupKey  String   @unique @map("dedup_key")
  tipCents  Int      @map("tip_cents")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([paymentId])
  @@index([tripId])
  @@map("tip_additions")
  @@schema("payment")
}

/// Confirmación bilateral de pago en efectivo (BR-P03): conductor "recibí" + pasajero "entregué".
model CashConfirmation {
  id                 String   @id @db.Uuid
  tripId             String   @unique @map("trip_id") @db.Uuid
  driverConfirmed    Boolean  @default(false) @map("driver_confirmed")
  passengerConfirmed Boolean  @default(false) @map("passenger_confirmed")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("cash_confirmations")
  @@schema("payment")
}

/// Afiliación de wallet (Yape On File · ProntoPaga). UN registro vivo por (userId, provider, wallet).
/// SEGURIDAD: `walletUid` es el secreto que habilita cobros server-initiated; vive SOLO server-side y
/// NUNCA sale en DTOs (los getters del servicio lo excluyen). `phoneMasked`/`documentMasked` guardan PII
/// enmascarada para mostrar (ej. "9****1234"). El deepLink (para aprobar la afiliación) SÍ va al cliente,
/// pero es efímero y NO se persiste.
model WalletAffiliation {
  id             String            @id @db.Uuid
  userId         String            @map("user_id") @db.Uuid
  /// Proveedor del riel (por ahora solo PRONTOPAGA).
  provider       String            @default("PRONTOPAGA")
  /// Wallet afiliada (por ahora solo YAPE).
  wallet         String            @default("YAPE")
  /// Tipo de afiliación. RECURRENT implementado; ON_DEMAND fuera de alcance (L1).
  type           String            @default("RECURRENT")
  status         AffiliationStatus @default(PROCESS)
  /// UID de la afiliación en el proveedor. SOLO server-side. Null hasta que el proveedor lo emita.
  walletUid      String?           @map("wallet_uid")
  /// Teléfono enmascarado (PII mínima para UI; nunca el número completo).
  phoneMasked    String?           @map("phone_masked")
  /// Documento enmascarado (PII mínima para UI).
  documentMasked String?           @map("document_masked")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  /// Una sola afiliación por usuario + proveedor + wallet (re-afiliar reusa/actualiza la fila).
  @@unique([userId, provider, wallet])
  @@index([status])
  @@index([walletUid])
  @@map("wallet_affiliations")
  @@schema("payment")
}

/// Corrida de conciliación contra extractos del gateway (BR-P07): cron diario 04:00.
model ReconciliationRun {
  id             String   @id @db.Uuid
  ranAt          DateTime @default(now()) @map("ran_at") @db.Timestamptz
  /// Discrepancia (0..1) entre lo capturado en DB y el extracto del gateway.
  discrepancyPct Float    @map("discrepancy_pct")
  alerted        Boolean  @default(false)
  /// Detalle (conteos/sumas comparadas) para auditoría.
  details        Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([ranAt])
  @@map("reconciliation_runs")
  @@schema("payment")
}

/// Catálogo de promociones/cupones (Ola 2A). `code` UNIQUE (normalizado a MAYÚSCULAS).
/// El descuento reduce SOLO lo que paga el pasajero sobre el bruto (`grossCents`); la comisión de
/// plataforma y la propina NO se ven afectadas (BR: la plataforma asume el costo de la promo).
/// `discount(grossCents)`:
///   PERCENTAGE → floor(grossCents * value / 100), topado por `maxDiscountCents` (si > 0)
///   FIXED      → min(value, grossCents)  (value en céntimos)
model Promotion {
  id              String    @id @db.Uuid
  code            String    @unique
  kind            PromoKind
  /// PERCENTAGE: 1..100 (porcentaje). FIXED: céntimos PEN de descuento.
  value           Int
  /// Tope de descuento en céntimos (solo PERCENTAGE). 0/null = sin tope.
  maxDiscountCents Int?     @map("max_discount_cents")
  /// Monto mínimo de bruto para aplicar (céntimos). 0 = sin mínimo.
  minFareCents    Int       @default(0) @map("min_fare_cents")
  /// Vigencia. `startsAt` null = ya vigente; `endsAt` null = sin caducidad.
  startsAt        DateTime? @map("starts_at") @db.Timestamptz
  endsAt          DateTime? @map("ends_at") @db.Timestamptz
  /// Usos máximos totales (0 = ilimitado) y por usuario (>=1).
  maxTotalUses    Int       @default(0) @map("max_total_uses")
  maxUsesPerUser  Int       @default(1) @map("max_uses_per_user")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  redemptions PromoRedemption[]

  @@index([active])
  @@map("promotions")
  @@schema("payment")
}

/// Canje de una promoción por un usuario en un viaje (Ola 2A). Idempotente por `dedupKey` (UNIQUE).
/// La unicidad (promotionId, userId, tripId) evita doble canje del mismo viaje; el límite por
/// usuario/regla se valida contando redenciones del usuario sobre la promo.
model PromoRedemption {
  id            String    @id @db.Uuid
  promotionId   String    @map("promotion_id") @db.Uuid
  promotion     Promotion @relation(fields: [promotionId], references: [id])
  code          String
  userId        String    @map("user_id") @db.Uuid
  tripId        String    @map("trip_id") @db.Uuid
  discountCents Int       @map("discount_cents")
  /// Clave de idempotencia del canje. UNIQUE.
  dedupKey      String    @unique @map("dedup_key")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([promotionId, userId, tripId])
  @@index([promotionId, userId])
  @@index([tripId])
  @@map("promo_redemptions")
  @@schema("payment")
}

/// Tipo de incentivo al conductor (Ola 2C).
enum IncentiveType {
  META_VIAJES // completa N viajes en la ventana → bono fijo (rewardCents)
  HORA_PICO //   multiplicador de ganancias en una franja horaria (multiplierBps)

  @@schema("payment")
}

/// Catálogo de incentivos al conductor (Ola 2C). Vive en payment-service (mismo bounded context
/// "dinero": el bono es un crédito en céntimos). La ventana [startsAt, endsAt] acota la vigencia.
///  - META_VIAJES: `targetTrips` (>0) y `rewardCents` (>0). Al alcanzar la meta se otorga el bono.
///  - HORA_PICO:   `multiplierBps` (>0; 12000 = +20% sobre 1.0) y `peakStartMinute`/`peakEndMinute`
///                 (minutos desde medianoche, hora local) definen la franja activa del día.
model Incentive {
  id              String        @id @db.Uuid
  type            IncentiveType
  title           String
  description     String
  /// Viajes objetivo (META_VIAJES). 0 si no aplica.
  targetTrips     Int           @default(0) @map("target_trips")
  /// Bono en céntimos PEN al completar (META_VIAJES). 0 si no aplica.
  rewardCents     Int           @default(0) @map("reward_cents")
  /// Multiplicador de ganancias en puntos básicos de %·100 (HORA_PICO). 0 si no aplica.
  multiplierBps   Int           @default(0) @map("multiplier_bps")
  /// Franja horaria (minutos desde medianoche, hora local) para HORA_PICO. Null si no aplica.
  peakStartMinute Int?          @map("peak_start_minute")
  peakEndMinute   Int?          @map("peak_end_minute")
  /// Vigencia. `startsAt` null = ya vigente; `endsAt` null = sin caducidad.
  startsAt        DateTime?     @map("starts_at") @db.Timestamptz
  endsAt          DateTime?     @map("ends_at") @db.Timestamptz
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  progress IncentiveProgress[]
  credits  IncentiveTripCredit[]

  @@index([active])
  @@map("incentives")
  @@schema("payment")
}

/// Progreso de UN conductor en UN incentivo (Ola 2C). Único por (incentiveId, driverId).
/// `tripsCompleted` se incrementa al consumir `trip.completed`; al alcanzar la meta se marca
/// `completedAt` y se otorga `rewardGrantedCents` (idempotente: solo una vez).
model IncentiveProgress {
  id                 String    @id @db.Uuid
  incentiveId        String    @map("incentive_id") @db.Uuid
  incentive          Incentive @relation(fields: [incentiveId], references: [id])
  driverId           String    @map("driver_id") @db.Uuid
  tripsCompleted     Int       @default(0) @map("trips_completed")
  completedAt        DateTime? @map("completed_at") @db.Timestamptz
  rewardGrantedCents Int       @default(0) @map("reward_granted_cents")
  /// Liquidación del bono (fix payout-link). `paidAt` NULL = bono concedido pero aún NO pagado: es el
  /// guard de idempotencia del marcado (CAS `paidAt:null`). `paidInPayoutId` ata el bono a SU Payout
  /// (trazabilidad contable). El collectEarnings de payouts barre los pendientes y los marca en la
  /// MISMA tx que crea el Payout.
  paidAt             DateTime? @map("paid_at") @db.Timestamptz
  paidInPayoutId     String?   @map("paid_in_payout_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([incentiveId, driverId])
  @@index([driverId])
  /// "bonos pendientes de un conductor" (paidAt IS NULL) sin escanear: collectEarnings y back-pay.
  @@index([driverId, paidAt])
  // Confirmación de desembolso: updateMany where {paidInPayoutId, paidAt:null} marca los bonos de ESE payout.
  @@index([paidInPayoutId])
  // Back-pay por arrastre: escanea bonos PENDIENTES (paidAt:null + completedAt en ventana) SIN driverId.
  @@index([paidAt, completedAt])
  @@map("incentive_progress")
  @@schema("payment")
}

/// Crédito de UN viaje a UN incentivo de UN conductor (Ola 2C). UNIQUE (incentiveId, driverId,
/// tripId): garantiza que un `trip.completed` re-entregado NO cuente el viaje dos veces (idempotencia).
model IncentiveTripCredit {
  id          String    @id @db.Uuid
  incentiveId String    @map("incentive_id") @db.Uuid
  incentive   Incentive @relation(fields: [incentiveId], references: [id])
  driverId    String    @map("driver_id") @db.Uuid
  tripId      String    @map("trip_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([incentiveId, driverId, tripId])
  @@index([driverId, tripId])
  @@map("incentive_trip_credits")
  @@schema("payment")
}

/// Outbox (FOUNDATION §6). Misma transacción que la mutación de dominio.
model OutboxEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq         BigInt    @default(autoincrement())
  aggregateId String    @map("aggregate_id")
  eventType   String    @map("event_type")
  envelope    Json
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  publishedAt DateTime? @map("published_at") @db.Timestamptz
  claimedAt   DateTime? @map("claimed_at") @db.Timestamptz
  failedAt    DateTime? @map("failed_at") @db.Timestamptz

  @@index([publishedAt, failedAt, claimedAt, createdAt, seq], map: "outbox_events_claim_idx")
  @@map("outbox_events")
  @@schema("payment")
}

/// Saldo de crédito GASTABLE de un usuario (céntimos PEN · Ola 2A · redención de referidos). Lo ALIMENTA el
/// consumer de `referral.rewarded` (Lote A); lo GASTA el cobro del viaje (Lote B). payment-service es dueño
/// de este saldo: identity guarda "ganado de por vida" (`User.referralRewardCents`, display), payment guarda
/// lo "gastable" acá — así el descuento se aplica y DECREMENTA en la MISMA tx ACID del cobro (sin doble-gasto
/// cross-service). Un registro por usuario; `balanceCents` nunca negativo (lo garantiza el gasto en Lote B).
model UserCredit {
  userId       String   @id @map("user_id") @db.Uuid
  balanceCents Int      @default(0) @map("balance_cents")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  entries UserCreditEntry[]

  @@map("user_credits")
  @@schema("payment")
}

/// Movimiento del ledger de crédito (append-only · auditable · Ola 2A). `deltaCents` > 0 = acreditación
/// (referral), < 0 = gasto (cobro · Lote B). `sourceRef` UNIQUE = la idempotencia financiera (§3 CLAUDE):
/// un `referral.rewarded` re-entregado (mismo eventId) viola el UNIQUE → la tx aborta → NO re-acredita.
/// `source` tipa el origen del movimiento (sin string mágico).
model UserCreditEntry {
  id         String       @id @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  credit     UserCredit   @relation(fields: [userId], references: [userId])
  deltaCents Int          @map("delta_cents")
  source     CreditSource
  /// Clave de idempotencia del movimiento: eventId del `referral.rewarded` que lo originó. UNIQUE.
  sourceRef  String       @unique @map("source_ref")
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@map("user_credit_entries")
  @@schema("payment")
}

/// Origen de un movimiento del ledger de crédito (Ola 2A).
///  - REFERRAL:        acreditación (delta > 0) por `referral.rewarded`.
///  - TRIP_REDEMPTION: gasto (delta < 0) al aplicarse el crédito en el cobro de un viaje (Lote B).
enum CreditSource {
  REFERRAL
  TRIP_REDEMPTION

  @@schema("payment")
}

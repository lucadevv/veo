# audit-service · entorno DEV (tracked, sin secretos reales). Cargar antes de bootear en local.
# Convención del repo (igual que identity/places): config NO secreta acá; los secretos van en
# `dev.secret.env` (gitignored). En dev los defaults del env.schema ya bastan para arrancar.
NODE_ENV=development
PORT=3009
LOG_LEVEL=debug

# Base de datos (schema "audit") — veo-postgres en :5433.
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=audit
DATABASE_URL_REPLICA=postgresql://veo:veo_dev@localhost:5433/veo?schema=audit

# Kafka — audit-service CONSUME los eventos auditables del resto del dominio — veo-kafka en :9094.
KAFKA_BROKERS=localhost:9094
KAFKA_GROUP_ID=audit-service
KAFKA_FROM_BEGINNING=false

# gRPC (registro/verificación síncrona desde otros servicios).
GRPC_URL=0.0.0.0:50059

# === Réplica inmutable WORM a S3/MinIO (Object Lock, modo COMPLIANCE). dev-stack en :9002. ===
AUDIT_S3_ENABLED=true
AUDIT_S3_ENDPOINT=http://localhost:9002
AUDIT_S3_REGION=us-east-1
AUDIT_S3_BUCKET=veo-audit-log
AUDIT_S3_ACCESS_KEY=veo_dev
AUDIT_S3_FORCE_PATH_STYLE=true
AUDIT_S3_RETENTION_DAYS=2557
AUDIT_S3_RELAY_INTERVAL_MS=1000

# Observabilidad (Jaeger OTLP del dev-stack).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Secretos: vacíos acá; los valores reales viven en dev.secret.env (gitignored).
INTERNAL_IDENTITY_SECRET=
AUDIT_S3_SECRET_KEY=

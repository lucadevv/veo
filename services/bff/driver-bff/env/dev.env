# driver-bff · entorno DEV (tracked, SIN secretos). Cargar antes de bootear en local.
# Los secretos (clave pública JWT SPKI + HMAC interno) van en `dev.secret.env` (GITIGNORED),
# generado por dev-stack/boot-passenger-stack.sh.
NODE_ENV=development
PORT=4002
LOG_LEVEL=debug

# CORS abierto en dev.
CORS_ORIGINS=*

# JWT: issuer/audience deben coincidir con los de identity (JWT_ISSUER/JWT_AUDIENCE).
VEO_JWT_ISSUER=veo-identity
VEO_JWT_AUDIENCE=veo-app

# Infra (dev-stack).
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9094
KAFKA_GROUP_ID=driver-bff

# Mapas (navegación turn-by-turn). osrm = motor local self-hosted; 'mapbox' = Directions API
# (token pk público, server-side) con fallback al motor local. El token (pk) va en dev.secret.env
# (GITIGNORED) como MAPBOX_ACCESS_TOKEN, obligatorio solo cuando VEO_MAPS_MODE=mapbox.
VEO_MAPS_MODE=osrm
OSRM_URL=http://localhost:5000
# Nominatim self-hosted del dev-stack. Puerto host 8089.
NOMINATIM_URL=http://localhost:8089

# gRPC downstream (LECTURAS): host:port de cada microservicio.
IDENTITY_GRPC_URL=localhost:50051
TRIP_GRPC_URL=localhost:50052
DISPATCH_GRPC_URL=localhost:50053
PAYMENT_GRPC_URL=localhost:50055
RATING_GRPC_URL=localhost:50060
FLEET_GRPC_URL=localhost:50062

# REST interno downstream (COMANDOS): base http de cada microservicio.
IDENTITY_URL=http://localhost:3001
TRIP_URL=http://localhost:3002
DISPATCH_URL=http://localhost:3003
PAYMENT_URL=http://localhost:3005
PAYOUTS_URL=http://localhost:3005
NOTIFICATION_URL=http://localhost:3008
FLEET_URL=http://localhost:3012
MEDIA_URL=http://localhost:3007
# chat-service (Ola 2A): historial + persistencia de mensajes del viaje.
CHAT_URL=http://localhost:3014

# Rate limiting (ventana fija por IP+usuario+ruta).
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=120

# Timeout de las llamadas REST internas (ms).
DOWNSTREAM_TIMEOUT_MS=8000

# Observabilidad (Jaeger OTLP del dev-stack).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Secretos (VACÍOS en dev.env; valores reales en dev.secret.env GITIGNORED) ──
# Clave PÚBLICA SPKI para verificar el JWT que firma identity. Si falta en dev se genera un par efímero.
VEO_JWT_PUBLIC_PEM=
# HMAC de identidad interna (BFF→service). DEBE coincidir con el de los microservicios.
VEO_INTERNAL_IDENTITY_SECRET=

# public-bff · secretos DEV (PLANTILLA tracked). Copiar a `development.env` (GITIGNORED) y completar.
# El boot del passenger-stack (dev-stack/boot-passenger-stack.sh) genera el development.env real.
#
# Solo la clave PÚBLICA (SPKI) para VALIDAR el JWT que firma identity con su privada PKCS#8.
# Debe ser EXACTAMENTE la pareja del JWT_PRIVATE_KEY_PEM de identity, o todo token externo da 401.
VEO_JWT_PUBLIC_PEM=
# HMAC de identidad interna. DEBE ser idéntico al INTERNAL_IDENTITY_SECRET de identity + places.
# La identidad firmada ahora porta además un claim de RIEL `aud` (este BFF firma 'public-rail'),
# verificado per-service fail-closed. Es una constante de compilación (NO un env): no se agrega var nueva.
VEO_INTERNAL_IDENTITY_SECRET=
# HMAC para verificar la firma del payload de pánico recibido del cliente (auth.service lo exige
# con getOrThrow). secret() → falla en prod si falta o es el de dev.
PANIC_HMAC_SECRET=
# Token PÚBLICO de Mapbox (`pk`). Requerido solo cuando VEO_MAPS_MODE=mapbox (server-side, sin SDK).
MAPBOX_ACCESS_TOKEN=
# === gRPC interno · transporte TLS (mTLS) — ADR-016 ==========================
# Contrato OPCIONAL (default ausente = insecure). Las 3 rutas presentes -> mTLS
# (cifra + verifica el peer contra la CA interna). Ausentes (dev/test) -> texto
# plano; el HMAC sigue dando auth+integridad. Mezcla parcial (1-2 de 3) -> fail-fast.
# Se provisionan en el DEPLOY (CA interna + cert por servicio via SOPS+age /
# docker-secrets, paso de bootstrap-vps). Sin valores en la plantilla.
# GRPC_TLS_CA_PATH=/run/secrets/grpc-ca.pem
# GRPC_TLS_CERT_PATH=/run/secrets/grpc-svc.crt.pem
# GRPC_TLS_KEY_PATH=/run/secrets/grpc-svc.key.pem
# GRPC_TLS_REQUIRED=true   # enforcement: con la PKI provisionada, prod RECHAZA arrancar sin mTLS (ADR-016). Default false.

# === Tier de despliegue ======================================================
# Tier lógico: local | dev | preview | production. Lo setea el runner (veo.sh exporta según APP_ENV;
# docker-compose.preview.yml lo pinea a preview vía environment). Este archivo puede fijarlo explícito
# (gana sobre el export del runner). @veo/utils deployTier() lo lee; default seguro = production.
# VEO_DEPLOY_TIER=dev

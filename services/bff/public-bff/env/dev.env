# public-bff · entorno DEV (tracked, SIN secretos). Cargar antes de bootear en local.
# Los secretos (clave pública JWT SPKI + HMAC interno) van en `dev.secret.env` (GITIGNORED),
# generado por dev-stack/boot-passenger-stack.sh.
NODE_ENV=development
PORT=4001
LOG_LEVEL=debug

# JWT: issuer/audience deben coincidir con los de identity (JWT_ISSUER/JWT_AUDIENCE).
VEO_JWT_ISSUER=veo-identity
VEO_JWT_AUDIENCE=veo-app

# Infra (dev-stack).
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9094

# Mapas en modo MAPBOX: search/ruteo vía las APIs HTTP de Mapbox (token público `pk`, server-side,
# SIN SDK). Devuelve CUALQUIER dirección de Lima CON NÚMERO (lo que Nominatim no tenía). El ruteo y
# la búsqueda degradan al motor local determinista si Mapbox falla o no hay red — no bloquea la
# búsqueda. El token (pk) va en dev.secret.env (GITIGNORED) como MAPBOX_ACCESS_TOKEN.
VEO_MAPS_MODE=mapbox
# Nominatim self-hosted del dev-stack (solo se usa en modo osrm). Puerto host 8089.
NOMINATIM_URL=http://localhost:8089

# gRPC downstream (lecturas). places-service en :50063 (lugares guardados del pasajero).
IDENTITY_GRPC_URL=localhost:50051
PLACES_GRPC_URL=localhost:50063
# trip-service en :50052 (detalle del viaje). EXPLÍCITO para no caer en un default rancio del binario:
# el getTripDetail del bff pegaba a :50060 (puerto de rating) cuando este valor faltaba → 500 ECONNREFUSED.
TRIP_GRPC_URL=localhost:50052
# dispatch-service en :50053 (surge + nearby drivers). Explícito por el mismo motivo.
DISPATCH_GRPC_URL=localhost:50053

# REST interno downstream (comandos). identity HTTP en :3091 (puerto dev del passenger-stack).
IDENTITY_URL=http://localhost:3091/api/v1

# CORS abierto en dev.
CORS_ORIGINS=*

# Observabilidad (Jaeger OTLP del dev-stack).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

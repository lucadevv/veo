# admin-bff · entorno DEV (tracked, SIN secretos). Cargar antes de bootear en local.
# Los secretos (clave pública JWT SPKI + HMAC interno + password ClickHouse) van en
# `dev.secret.env` (GITIGNORED), generado por dev-stack/boot-passenger-stack.sh.
NODE_ENV=development
PORT=4003
LOG_LEVEL=debug

# CORS: origen del admin-web (Next.js). En prod, dominio real.
# Puerto 5001 (no 5000): el 5000 lo ocupa el AirPlay Receiver de macOS — admin-web reasignado a 5001.
ADMIN_WEB_ORIGIN=http://localhost:5001

# JWT: issuer/audience deben coincidir con los de identity (JWT_ISSUER/JWT_AUDIENCE).
VEO_JWT_ISSUER=veo-identity
VEO_JWT_AUDIENCE=veo-app

# Infra (dev-stack).
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9094
KAFKA_CONSUMER_GROUP=admin-bff

# ClickHouse (analítica vía interfaz HTTP). User/DB/URL son públicos; el password va en dev.secret.env.
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=veo_analytics
CLICKHOUSE_USER=veo

# Rate limiting (Redis, por IP+usuario).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Observabilidad (Jaeger OTLP del dev-stack).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── gRPC downstream (LECTURAS): host:port de cada microservicio. ──
IDENTITY_GRPC_URL=localhost:50051
TRIP_GRPC_URL=localhost:50052
DISPATCH_GRPC_URL=localhost:50053
PAYMENT_GRPC_URL=localhost:50055
PANIC_GRPC_URL=localhost:50056
MEDIA_GRPC_URL=localhost:50057
AUDIT_GRPC_URL=localhost:50059
RATING_GRPC_URL=localhost:50060
FLEET_GRPC_URL=localhost:50062

# ── REST interno firmado (COMANDOS) — todos /api/v1 ──
IDENTITY_URL=http://localhost:3091/api/v1
TRIP_URL=http://localhost:3092/api/v1
DISPATCH_URL=http://localhost:3093/api/v1
PAYMENT_URL=http://localhost:3005/api/v1
PANIC_URL=http://localhost:3006/api/v1
MEDIA_URL=http://localhost:3007/api/v1
AUDIT_URL=http://localhost:3009/api/v1
FLEET_URL=http://localhost:3012/api/v1

# ── Secretos (VACÍOS en dev.env; valores reales en dev.secret.env GITIGNORED) ──
# Clave PÚBLICA SPKI para verificar el JWT que firma identity.
VEO_JWT_PUBLIC_PEM=
# HMAC de identidad interna (BFF→service). DEBE coincidir con el de los microservicios.
VEO_INTERNAL_IDENTITY_SECRET=
# Password de ClickHouse. Usa secret() tras el fix reciente → vacío aquí, en dev.secret.env.
CLICKHOUSE_PASSWORD=

# media-service · entorno DEV (tracked, sin secretos reales). Cargar antes de bootear en local.
# Convención del repo (igual que identity/places): config NO secreta acá; los secretos van en
# `dev.secret.env` (gitignored). En dev los defaults del env.schema ya bastan para arrancar.
# Orquesta LiveKit self-hosted (:7880) + grabaciones a S3/MinIO (:9002) — BR-S01/S02/S03.
NODE_ENV=development
PORT=3007
LOG_LEVEL=debug

# Base de datos (schema "media") — veo-postgres en :5433.
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=media
DATABASE_URL_REPLICA=postgresql://veo:veo_dev@localhost:5433/veo?schema=media

# Redis (idempotencia de consumidores + locks de grabación) — veo-redis en :6379.
REDIS_URL=redis://localhost:6379

# Kafka (outbox relay + consumidores de dominio) — veo-kafka en :9094.
KAFKA_BROKERS=localhost:9094

# === LiveKit self-hosted (WebRTC). Sin SaaS: servidor propio (dev-stack en :7880). ===
VEO_LIVEKIT_MODE=sandbox
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_TOKEN_TTL_SECONDS=3600

# === Almacenamiento de grabaciones: S3/MinIO self-hosted (forcePathStyle), dev-stack en :9002. ===
VEO_STORAGE_MODE=sandbox
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY=veo_dev
S3_BUCKET_VIDEO=veo-video-dev
S3_BUCKET_AVATAR=veo-avatars-dev
S3_PUBLIC_BASE_URL=http://localhost:9002
AVATAR_MAX_BYTES=5242880
S3_FORCE_PATH_STYLE=true
KMS_KEY_ID_VIDEO=alias/veo-video

# === Retención (BR-S03) ===
RETENTION_DEFAULT_DAYS=30
RETENTION_INCIDENT_DAYS=180
SIGNED_URL_TTL_SECONDS=300

# Observabilidad (Jaeger OTLP del dev-stack).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# gRPC (lectura síncrona: veo.media.v1).
GRPC_URL=0.0.0.0:50057

# Secretos: vacíos acá; los valores reales viven en dev.secret.env (gitignored).
INTERNAL_IDENTITY_SECRET=
LIVEKIT_API_SECRET=
S3_SECRET_KEY=

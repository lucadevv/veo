# media-service · secretos DEV (PLANTILLA). Copiar a `development.env` (gitignored) y completar.
# En dev local los defaults del env.schema bastan; este archivo solo si querés sobreescribir un secreto.
# LIVEKIT_API_SECRET firma los tokens WebRTC de la cámara en vivo (debe coincidir con el LIVEKIT_KEYS
# del dev-stack: "devkey: devsecret_change_in_production"). S3_SECRET_KEY = credencial del storage
# soberano de VIDEO (Ley 29733). En prod ambos vienen de Secrets Manager (fail-fast con los de dev).
INTERNAL_IDENTITY_SECRET=dev-internal-secret-change-me
LIVEKIT_API_SECRET=devsecret_change_in_production
S3_SECRET_KEY=veo_dev_secret

# === Presign audience-aware (NO secretos · contrato de hosts del presign) ===
# DEVICE/LAN: firma el presign de la app del conductor/pasajero (teléfono). En dev = IP LAN del Mac.
S3_PUBLIC_BASE_URL=http://192.168.18.224:9002
# ADMIN/browser del Mac: firma el presign-GET del visor del operador (admin-bff). localhost estable.
S3_ADMIN_BASE_URL=http://localhost:9002
# === gRPC interno · transporte TLS (mTLS) — ADR-016 ==========================
# Contrato OPCIONAL (default ausente = insecure). Las 3 rutas presentes -> mTLS
# (cifra + verifica el peer contra la CA interna). Ausentes (dev/test) -> texto
# plano; el HMAC sigue dando auth+integridad. Mezcla parcial (1-2 de 3) -> fail-fast.
# Se provisionan en el DEPLOY (CA interna + cert por servicio via SOPS+age /
# docker-secrets, paso de bootstrap-vps). Sin valores en la plantilla.
# GRPC_TLS_CA_PATH=/run/secrets/grpc-ca.pem
# GRPC_TLS_CERT_PATH=/run/secrets/grpc-svc.crt.pem
# GRPC_TLS_KEY_PATH=/run/secrets/grpc-svc.key.pem
# GRPC_TLS_REQUIRED=true   # enforcement: con la PKI provisionada, prod RECHAZA arrancar sin mTLS (ADR-016). Default false.

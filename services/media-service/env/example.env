# media-service · secretos DEV (PLANTILLA). Copiar a `development.env` (gitignored) y completar.
# En dev local los defaults del env.schema bastan; este archivo solo si querés sobreescribir un secreto.
# LIVEKIT_API_SECRET firma los tokens WebRTC de la cámara en vivo (debe coincidir con el LIVEKIT_KEYS
# del dev-stack: "devkey: devsecret_change_in_production"). S3_SECRET_KEY = credencial del storage
# soberano de VIDEO (Ley 29733). En prod ambos vienen de Secrets Manager (fail-fast con los de dev).
INTERNAL_IDENTITY_SECRET=dev-internal-secret-change-me
LIVEKIT_API_SECRET=devsecret_change_in_production
S3_SECRET_KEY=veo_dev_secret

# === Presign audience-aware (NO secretos · contrato de hosts del presign) ===
# DEVICE/LAN: firma el presign de la app del conductor/pasajero (teléfono). En dev = IP LAN del Mac.
S3_PUBLIC_BASE_URL=http://192.168.18.224:9002
# ADMIN/browser del Mac: firma el presign-GET del visor del operador (admin-bff). localhost estable.
S3_ADMIN_BASE_URL=http://localhost:9002
# === Watermark burn-in (NO secretos · ffmpeg server-side, ports&adapters) ====
# En dev los defaults del env.schema bastan; este bloque solo si querés sobreescribir.
# Modo: sandbox (passthrough sin ffmpeg, default) o live (invoca el binario ffmpeg).
# VEO_WATERMARK_MODE=sandbox
# Binario ffmpeg. En el image alpine va en el PATH ('ffmpeg'); en host nativo puede ser absoluto.
# WATERMARK_FFMPEG_PATH=ffmpeg
# Fuente TTF de drawtext. En el image = paquete alpine 'ttf-dejavu' (instala en /usr/share/fonts/dejavu/).
# En host macOS apuntá a una fuente real, p.ej. /System/Library/Fonts/Supplemental/Arial.ttf
# WATERMARK_FONT_PATH=/usr/share/fonts/dejavu/DejaVuSans.ttf
# Render: altura máx (downscale), CRF, preset libx264, timeout duro (ms → SIGKILL).
# WATERMARK_MAX_HEIGHT=720
# WATERMARK_CRF=28
# WATERMARK_PRESET=veryfast
# WATERMARK_RENDER_TIMEOUT_MS=120000
# Worker de render (Lote 3 · quema lazy de watermark + reaper de PROCESSING colgados). SIN secretos.
# Intervalo del worker (s), tamaño de batch (secuencial), cap de intentos, prefijo de las copias derivadas,
# TTL del lock distribuido (> batch × render timeout) y antigüedad de PROCESSING colgado (> render timeout).
# WATERMARK_RENDER_INTERVAL_SECONDS=20
# WATERMARK_RENDER_BATCH=3
# WATERMARK_RENDER_MAX_ATTEMPTS=3
# WATERMARK_RENDERED_PREFIX=watermarked/
# WATERMARK_RENDER_LOCK_TTL_SECONDS=900
# WATERMARK_RENDER_STALE_SECONDS=600
# === gRPC interno · transporte TLS (mTLS) — ADR-016 ==========================
# Contrato OPCIONAL (default ausente = insecure). Las 3 rutas presentes -> mTLS
# (cifra + verifica el peer contra la CA interna). Ausentes (dev/test) -> texto
# plano; el HMAC sigue dando auth+integridad. Mezcla parcial (1-2 de 3) -> fail-fast.
# Se provisionan en el DEPLOY (CA interna + cert por servicio via SOPS+age /
# docker-secrets, paso de bootstrap-vps). Sin valores en la plantilla.
# GRPC_TLS_CA_PATH=/run/secrets/grpc-ca.pem
# GRPC_TLS_CERT_PATH=/run/secrets/grpc-svc.crt.pem
# GRPC_TLS_KEY_PATH=/run/secrets/grpc-svc.key.pem
# GRPC_TLS_REQUIRED=true   # enforcement: con la PKI provisionada, prod RECHAZA arrancar sin mTLS (ADR-016). Default false.

# === Tier de despliegue ======================================================
# Tier lógico: local | dev | preview | production. Lo setea el runner (veo.sh exporta según APP_ENV;
# docker-compose.preview.yml lo pinea a preview vía environment). Este archivo puede fijarlo explícito
# (gana sobre el export del runner). @veo/utils deployTier() lo lee; default seguro = production.
# VEO_DEPLOY_TIER=dev

// media-service · esquema Postgres (schema lógico "media")
// FOUNDATION §8. Dueño de: segmentos de video de viajes (LiveKit→S3) y el ciclo de acceso
// auditado a esos videos (doble autorización + watermark + retención legal).
// BR-S01 (cámara/grabación), BR-S02 (acceso a video), BR-S03 (retención).

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["media"]
}

/// Un segmento de grabación de un viaje (una room LiveKit grabada vía egress hacia S3).
/// retentionUntil NULL = retención indefinida (viaje con pánico, hasta resolución — BR-S03).
model MediaSegment {
  id              String    @id @db.Uuid
  tripId          String    @map("trip_id") @db.Uuid
  startedAt       DateTime  @map("started_at") @db.Timestamptz
  endedAt         DateTime? @map("ended_at") @db.Timestamptz
  /// Clave del objeto en S3/MinIO (bucket de video). Vacía hasta que el egress confirma destino.
  s3Key           String    @map("s3_key")
  /// Tamaño del objeto archivado en bytes (int64; video puede superar 2 GB).
  sizeBytes       BigInt    @default(0) @map("size_bytes")
  codec           String    @default("h264")
  /// Referencia a la clave KMS con la que se cifra el video en reposo (nunca la clave en claro).
  encryptionKeyId String    @map("encryption_key_id")
  /// Fecha límite de retención. NULL = indefinido (pánico). Pasado = elegible para barrido.
  retentionUntil  DateTime? @map("retention_until") @db.Timestamptz
  accessedCount   Int       @default(0) @map("accessed_count")
  lastAccessedAt  DateTime? @map("last_accessed_at") @db.Timestamptz
  /// Id del egress de LiveKit que produce este segmento (para detenerlo al finalizar el viaje).
  egressId        String?   @map("egress_id")
  /// Bandera de incidente (retención extendida a 180 días — BR-S03).
  hasIncident     Boolean   @default(false) @map("has_incident")
  /// Bandera de pánico (retención indefinida — BR-S03).
  hasPanic        Boolean   @default(false) @map("has_panic")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  accessRequests  VideoAccessRequest[]

  @@index([tripId])
  @@index([retentionUntil])
  @@map("media_segments")
  @@schema("media")
}

/// Solicitud de acceso a un video (BR-S02). El operador la crea con un motivo (>20 chars); un
/// COMPLIANCE_SUPERVISOR con MFA fresca la aprueba, generando una URL firmada (5 min) + watermark.
/// Estado de la solicitud de acceso a video (BR-S02). PENDING al crearse; el supervisor la APRUEBA o
/// RECHAZA (doble-auth). EXPIRED reservado para cuando una aprobación tenga ventana de validez vencida.
enum VideoAccessStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED

  @@schema("media")
}

/// Estado del RENDER (quemado de watermark server-side) de la copia derivada — EJE SEPARADO de la
/// DECISIÓN de acceso (VideoAccessStatus). NULL en la solicitud = render nunca solicitado. State machine
/// del render: (null) → PENDING → PROCESSING → READY | FAILED. El operador NUNCA recibe la URL del video
/// CRUDO: streamAccess solo presigna la copia READY (`renderedS3Key`), jamás `MediaSegment.s3Key` (BR-S02).
enum VideoRenderStatus {
  PENDING
  PROCESSING
  READY
  FAILED

  @@schema("media")
}

model VideoAccessRequest {
  id                 String    @id @db.Uuid
  /// Segmento concreto al que se solicita acceso (opcional: se puede pedir por viaje completo).
  segmentId          String?   @map("segment_id") @db.Uuid
  segment            MediaSegment? @relation(fields: [segmentId], references: [id])
  tripId             String    @map("trip_id") @db.Uuid
  /// Operador que solicita el acceso (su id de usuario).
  requestedBy        String    @map("requested_by") @db.Uuid
  /// Email del operador solicitante — se incrusta como watermark dinámico en la visualización.
  requestedByEmail   String    @map("requested_by_email")
  /// Motivo de la solicitud. CHECK a nivel DB: longitud > 20 (BR-S02).
  reason             String
  /// Estado explícito de la solicitud (state machine: PENDING → APPROVED|REJECTED). Default PENDING.
  status             VideoAccessStatus @default(PENDING)
  /// Supervisor de cumplimiento que aprueba (su id de usuario).
  approvedBy         String?   @map("approved_by") @db.Uuid
  approvedAt         DateTime? @map("approved_at") @db.Timestamptz
  /// Supervisor que RECHAZA (su id de usuario) — cierra la solicitud sin otorgar acceso (auditado).
  rejectedBy         String?   @map("rejected_by") @db.Uuid
  rejectedAt         DateTime? @map("rejected_at") @db.Timestamptz
  signedUrlExpiresAt DateTime? @map("signed_url_expires_at") @db.Timestamptz
  /// Watermark de la última visualización (email del operador + timestamp + id de solicitud). Tras el
  /// burn-in (Lote 3) guarda el texto QUEMADO en la copia derivada (informativo para el cliente).
  watermark          String?
  /// EJE DE RENDER (separado del de decisión). Estado del quemado de watermark de la copia derivada.
  /// NULL = render nunca solicitado (una aprobación recién hecha no tiene render hasta el primer stream).
  renderStatus       VideoRenderStatus? @map("render_status")
  /// Clave S3/MinIO de la COPIA con watermark quemado (la ÚNICA que se presigna al operador). Set al READY.
  renderedS3Key      String?   @map("rendered_s3_key")
  /// Cuándo se SOLICITÓ el render (transición a PENDING) — orden del worker + detección de PROCESSING colgado.
  renderRequestedAt  DateTime? @map("render_requested_at") @db.Timestamptz
  /// Cuándo el render llegó a READY (copia derivada lista).
  renderedAt         DateTime? @map("rendered_at") @db.Timestamptz
  /// Motivo de la ÚLTIMA falla de render — SIN PII (solo categoría/mensaje técnico, truncado).
  renderError        String?   @map("render_error")
  /// Intentos de render consumidos (el worker lo incrementa al TOMAR la solicitud). Cap = MAX_ATTEMPTS.
  renderAttempts     Int       @default(0) @map("render_attempts")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([tripId])
  @@index([segmentId])
  @@index([requestedBy])
  @@index([status, createdAt])
  /// Índice del worker de render: barre PENDING / PROCESSING-colgado ordenado por renderRequestedAt.
  @@index([renderStatus, renderRequestedAt])
  @@map("video_access_requests")
  @@schema("media")
}

/// Outbox (FOUNDATION §6). Misma transacción que la mutación de dominio.
model OutboxEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq         BigInt    @default(autoincrement())
  aggregateId String    @map("aggregate_id")
  eventType   String    @map("event_type")
  envelope    Json
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  publishedAt DateTime? @map("published_at") @db.Timestamptz
  claimedAt   DateTime? @map("claimed_at") @db.Timestamptz
  failedAt    DateTime? @map("failed_at") @db.Timestamptz

  @@index([publishedAt, failedAt, claimedAt, createdAt, seq], map: "outbox_events_claim_idx")
  @@map("outbox_events")
  @@schema("media")
}

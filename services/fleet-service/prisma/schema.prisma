// fleet-service · esquema Postgres (schema lógico "fleet")
// FOUNDATION §8. Dueño de: vehículos, documentos con vencimiento (Licencia A1, SOAT,
// Tarjeta de propiedad, Antecedentes, ITV) e inspecciones técnicas trimestrales.
// La identidad del conductor/pasajero vive en identity-service (referenciada por id, sin FK cross-schema).

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["fleet"]
}

/// Tipo de documento de flota (BR-I04). Críticos: LICENSE_A1, SOAT, PROPERTY_CARD.
enum FleetDocumentType {
  LICENSE_A1
  SOAT
  PROPERTY_CARD
  BACKGROUND_CHECK
  ITV

  // B5-3.2 · certificaciones de operador de las verticales especiales (conductor). Misma maquinaria
  // FleetDocument (vencimiento + review). NO críticas: su vencimiento NO suspende, solo deshabilita la
  // vertical (que además está oculta). Espejo del FleetDocumentType de @veo/shared-types.
  AMBULANCE_OPERATOR
  TOW_OPERATOR
  MECHANIC_CERT

  @@schema("fleet")
}

/// Estado del documento. PENDING_REVIEW/REJECTED son manuales; VALID/EXPIRING_SOON/EXPIRED
/// se derivan del vencimiento (cron BR-I04).
enum FleetDocumentStatus {
  PENDING_REVIEW
  VALID
  EXPIRING_SOON
  EXPIRED
  REJECTED

  @@schema("fleet")
}

/// Dueño del documento: un conductor (driverId de identity) o un vehículo (id de fleet).
enum FleetOwnerType {
  DRIVER
  VEHICLE

  @@schema("fleet")
}

/// Estado documental agregado del vehículo (deriva de SOAT/ITV + seguro). BR-D04.
enum VehicleDocStatus {
  VALID
  EXPIRING_SOON
  EXPIRED

  @@schema("fleet")
}

/// Tipo de vehículo (Ola 2B · tier moto-taxi). Coincide con VehicleType de @veo/shared-types.
/// CAR = automóvil estándar (default histórico); MOTO = mototaxi. dispatch filtra el matching por
/// este tipo (un viaje MOTO solo se ofrece a conductores con vehículo MOTO).
enum VehicleType {
  CAR
  MOTO

  @@schema("fleet")
}

/// B5-2 · estado del modelo en el catálogo curado. APPROVED = curado por el operador (usable en el
/// onboarding); PENDING_REVIEW = solicitado por un conductor cuyo modelo no estaba (espera ficha del
/// operador); REJECTED = rechazado. Espeja el lifecycle de FleetDocumentStatus (manual: PENDING→APPROVED/REJECTED).
enum VehicleModelStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED

  @@schema("fleet")
}

/// Vehículo de la flota (BR-D04: año >= 2017; SOAT e ITV vigentes; inspección trimestral).
model Vehicle {
  id                 String           @id @db.Uuid
  plate              String           @unique
  make               String
  model              String
  year               Int
  color              String
  /// Ola 2B · tier moto-taxi: tipo de vehículo. Default CAR (compatibilidad con la flota existente).
  vehicleType        VehicleType      @default(CAR) @map("vehicle_type")
  fleetId            String?          @map("fleet_id")
  /// Conductor que registró el vehículo en el onboarding self-service.
  /// IMPORTANTE: `driver_id` es el **User.id** de identity-service (el `userId` del token propagado),
  /// NO el id de perfil `Driver` de identity. fleet no conoce identity, así que guarda el sujeto de la
  /// identidad propagada (User.id) tal cual; no traduce a id de perfil Driver. No confundir al operar.
  /// Null para la flota cargada por el operador. Sin FK cross-schema (la identidad vive en identity).
  driverId           String?          @map("driver_id") @db.Uuid
  docStatus          VehicleDocStatus @default(VALID) @map("doc_status")
  /// B5-2 · modelo del catálogo curado (VehicleModelSpec) que el conductor ELIGIÓ en el onboarding.
  /// Referencia BLANDA al catálogo (mismo schema, sin FK dura — espeja el estilo de driverId/fleetId):
  /// el catálogo puede evolucionar sin bloquear el vehículo. make/model se snapshotean en el alta desde
  /// el spec (histórico estable). Null = vehículo legacy/operador cargado a texto libre (pre-catálogo).
  modelSpecId        String?          @map("model_spec_id") @db.Uuid
  insuranceExpiresAt DateTime?        @map("insurance_expires_at") @db.Timestamptz
  active             Boolean          @default(true)
  /// Cuándo el conductor SELECCIONÓ este vehículo como su activo (el que opera). El vehículo activo
  /// del conductor = su vehículo con `selected_at` MÁS RECIENTE (con docs vigentes). Null = nunca
  /// seleccionado explícitamente; si ninguno lo está, el activo cae al más recientemente registrado.
  /// Es server-authoritative: el tipo que el dispatch usa sale de ESTE vehículo, no del ping del cliente.
  selectedAt         DateTime?        @map("selected_at") @db.Timestamptz
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  inspections Inspection[]

  @@index([fleetId])
  @@index([driverId])
  @@index([docStatus])
  @@index([modelSpecId])
  @@map("vehicles")
  @@schema("fleet")
}

/// B5-2 · CATÁLOGO CURADO de modelos de vehículo: la fuente de seats/segment/combustible/eficiencia por
/// make+model+rango de años. El conductor ELIGE de acá en el onboarding (no tipea make/model libre);
/// modelos nuevos entran PENDING_REVIEW y el operador los aprueba con la ficha de fábrica. La eficiencia
/// per-modelo es para la ECONOMÍA DEL CONDUCTOR (cuánto gasta); la tarifa del pasajero usa la referencia
/// POR CLASE de la oferta (el quote no conoce el vehículo). `segment`/`energySource` se persisten como
/// String (validados en el borde contra los enums de @veo/shared-types VehicleSegment/EnergySource).
model VehicleModelSpec {
  id           String             @id @db.Uuid
  make         String
  model        String
  yearFrom     Int                @map("year_from")
  yearTo       Int                @map("year_to")
  /// Tipo/forma del vehículo (CAR|MOTO hoy; VAN/TRUCK llegan con las verticales especiales, B5-4).
  vehicleType  VehicleType        @default(CAR) @map("vehicle_type")
  seats        Int
  /// VehicleSegment (@veo/shared-types): ECONOMY|MID|PREMIUM. NULL en una solicitud PENDING (el operador
  /// lo completa al aprobar). Invariante (B5-2.c): status=APPROVED ⇒ no-null (forzado en la transición).
  segment      String?
  /// EnergySource (@veo/shared-types): GASOLINE_95|DIESEL|ELECTRIC|GNV|GASOLINE_84. NULL en PENDING.
  energySource String?            @map("energy_source")
  /// Rendimiento en km por unidad de energía (km/L o km/kWh). Lo pone el operador al aprobar. NULL en PENDING.
  efficiency   Int?
  status       VehicleModelStatus @default(PENDING_REVIEW)
  /// User.id (identity) del conductor que solicitó el alta (null para los seedeados/curados por operador).
  requestedBy  String?            @map("requested_by") @db.Uuid
  verifiedBy   String?            @map("verified_by") @db.Uuid
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  /// Un modelo es único por make+model+añoDesde (evita duplicados al curar/solicitar).
  @@unique([make, model, yearFrom])
  @@index([status])
  @@map("vehicle_model_specs")
  @@schema("fleet")
}

/// Documento de conductor o vehículo con vencimiento (BR-I04).
model FleetDocument {
  id              String              @id @db.Uuid
  ownerType       FleetOwnerType      @map("owner_type")
  ownerId         String              @map("owner_id")
  type            FleetDocumentType
  documentNumber  String              @map("document_number")
  issuedAt        DateTime?           @map("issued_at") @db.Timestamptz
  expiresAt       DateTime?           @map("expires_at") @db.Timestamptz
  fileS3Key       String?             @map("file_s3_key")
  status          FleetDocumentStatus @default(PENDING_REVIEW)
  /// Último hito de alerta (en días) ya emitido para no duplicar (30/15/7/1). BR-I04.
  lastAlertedDays Int?                @map("last_alerted_days")
  verifiedAt      DateTime?           @map("verified_at") @db.Timestamptz
  verifiedBy      String?             @map("verified_by") @db.Uuid
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  @@index([ownerType, ownerId])
  @@index([status, expiresAt])
  @@map("fleet_documents")
  @@schema("fleet")
}

/// Inspección técnica del vehículo (BR-D04: trimestral, nextDueAt = inspectedAt + 3 meses).
model Inspection {
  id          String   @id @db.Uuid
  vehicleId   String   @map("vehicle_id") @db.Uuid
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  inspectorId String   @map("inspector_id") @db.Uuid
  inspectedAt DateTime @map("inspected_at") @db.Timestamptz
  passed      Boolean
  notes       String?
  nextDueAt   DateTime @map("next_due_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([vehicleId, inspectedAt])
  @@map("inspections")
  @@schema("fleet")
}

/// Outbox (FOUNDATION §6). Misma transacción que la mutación de dominio.
model OutboxEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregateId String    @map("aggregate_id")
  eventType   String    @map("event_type")
  envelope    Json
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  publishedAt DateTime? @map("published_at") @db.Timestamptz

  @@index([publishedAt, createdAt])
  @@map("outbox_events")
  @@schema("fleet")
}

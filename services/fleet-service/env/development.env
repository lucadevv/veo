# fleet-service · config DEV (tracked, SIN secretos). El INTERNAL_IDENTITY_SECRET vive en
# development.secret.env (gitignored), generado por dev-stack/boot-passenger-stack.sh.
NODE_ENV=development
PORT=3012
LOG_LEVEL=info

# Postgres compartido del dev-stack (schema propio fleet).
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=fleet

REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9094

# gRPC server (el bff lo consulta para enriquecer ofertas: GetVehicle → FLEET_GRPC_URL=localhost:50062).
GRPC_URL=0.0.0.0:50062

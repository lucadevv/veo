# booking-service · contrato de entorno (PLANTILLA tracked, SIN valores). Copiar a `development.env`
# (GITIGNORED) y completar. Marketplace de carpooling PROGRAMADO (ADR-014). Puertos fijos: REST 3016, gRPC 50054.

NODE_ENV=
PORT=
LOG_LEVEL=

# Base de datos — schema lógico propio "booking" (DB-per-service). NO comparte tablas con trip/payment/identity.
DATABASE_URL=
DATABASE_URL_REPLICA=

# Redis (reservado para gates/locks de fases futuras; el lock de asientos del §6 es F3).
REDIS_URL=

# Kafka (outbox relay → topic 'booking').
KAFKA_BROKERS=

# HMAC de identidad interna (firma la identidad propagada BFF→service). DEBE ser IDÉNTICO en TODOS los
# services y BFFs. Si difiere, el guard interno rechaza la request. secret() → falla en prod si falta o es el de dev.
INTERNAL_IDENTITY_SECRET=

# gRPC propio (expone booking.GetPublishedTrip/GetBooking — F2+).
GRPC_URL=

# gRPC SALIENTES (consumo síncrono):
# identity.GetDriver (gate F1a: status/suspensión/KYC/antecedentes del conductor antes de publicar).
IDENTITY_GRPC_URL=
# fleet.GetDriverVehicles (gate F1a anti-IDOR: pertenencia + vigencia del vehículo al publicar). fleet gRPC = :50062.
FLEET_GRPC_URL=
# payment.GetPayment (validar método al reservar + derivar gate de deuda — F1/F3).
PAYMENT_GRPC_URL=

# @veo/maps (F1b · tope de cost-sharing por distancia). ROUTING SOBERANO (§0.7): distancia de la ruta =
# SÓLO @veo/maps con motor propio self-hosted, NUNCA un tercero SaaS. Detrás del puerto MapsModule.
# VEO_MAPS_MODE: local (motor propio determinista, dev/CI) | osrm (infra OSM self-hosted, OBLIGATORIO en prod).
# mapbox NO está soportado a propósito (mandaría las coordenadas del viaje a un tercero — viola soberanía/privacidad).
VEO_MAPS_MODE=
OSRM_BASE_URL=
NOMINATIM_BASE_URL=
# Timeout por request al motor de rutas (ms). Gate FAIL-CLOSED: si OSRM no responde, no se publica.
MAPS_TIMEOUT_MS=

# Costo de referencia por km, por país (F1b · ESCUDO LEGAL anti-lucro, ADR-014 §8). Céntimos Int.
# ⚠️ VALORES PROVISIONALES — el DUEÑO debe VALIDARLOS con legal/finanzas ANTES de lanzar a prod
# (combustible + desgaste + peajes reales por país). Defaults del schema: PE=100 (S/1.00/km), EC=50.
COST_PER_KM_CENTS_PE=
COST_PER_KM_CENTS_EC=

OTEL_EXPORTER_OTLP_ENDPOINT=

# booking-service · contrato de entorno (PLANTILLA tracked, SIN valores). Copiar a `development.env`
# (GITIGNORED) y completar. Marketplace de carpooling PROGRAMADO (ADR-014). Puertos fijos: REST 3016, gRPC 50054.

NODE_ENV=
PORT=
LOG_LEVEL=

# Base de datos — schema lógico propio "booking" (DB-per-service). NO comparte tablas con trip/payment/identity.
DATABASE_URL=
DATABASE_URL_REPLICA=

# Redis (reservado para gates/locks de fases futuras; el lock de asientos del §6 es F3).
REDIS_URL=

# Kafka (outbox relay → topic 'booking').
KAFKA_BROKERS=

# HMAC de identidad interna (firma la identidad propagada BFF→service). DEBE ser IDÉNTICO en TODOS los
# services y BFFs. Si difiere, el guard interno rechaza la request. secret() → falla en prod si falta o es el de dev.
INTERNAL_IDENTITY_SECRET=

# gRPC propio (expone booking.GetPublishedTrip/GetBooking — F2+).
GRPC_URL=

# gRPC SALIENTES (consumo síncrono):
# identity.GetDriver (gate F1a: status/suspensión/KYC/antecedentes del conductor antes de publicar).
IDENTITY_GRPC_URL=
# fleet.GetDriverVehicles (gate F1a anti-IDOR: pertenencia + vigencia del vehículo al publicar). fleet gRPC = :50062.
FLEET_GRPC_URL=
# payment.GetPayment (leer estado/recibo del cobro ya disparado — gRPC, §5.4). payment gRPC = :50055 (NO :50052, ese es trip).
PAYMENT_GRPC_URL=

# Borde REST de payment (ADR-014 §5.5): el CHARGE (POST /charge · F3b) y el gate de DEUDA al reservar
# (GET /debt · F3a) son REST firmados service-rail, no gRPC. Apunta a la API interna de payment (/api/v1).
# Mismo patrón que share-service→notification (NOTIFICATION_INTERNAL_URL). payment REST = :3005.
PAYMENT_INTERNAL_URL=

# Registro central de políticas PBAC (@veo/policy · ADR-024): base del API interno REST de identity-service
# (incluye /api/v1; distinta de IDENTITY_GRPC_URL). GET /internal/policies firmado admin-rail al boot;
# inalcanzable → DEFAULT del catálogo (fail-safe, no tumba el arranque). Dev default: localhost:3001/api/v1.
IDENTITY_INTERNAL_URL=

# @veo/maps (F1b · tope de cost-sharing por distancia). ROUTING SOBERANO (§0.7): distancia de la ruta =
# SÓLO @veo/maps con motor propio self-hosted, NUNCA un tercero SaaS. Detrás del puerto MapsModule.
# VEO_MAPS_MODE: local (motor propio determinista, dev/CI) | osrm (infra OSM self-hosted, OBLIGATORIO en prod).
# mapbox NO está soportado a propósito (mandaría las coordenadas del viaje a un tercero — viola soberanía/privacidad).
VEO_MAPS_MODE=
OSRM_BASE_URL=
NOMINATIM_BASE_URL=
# Timeout por request al motor de rutas (ms). Gate FAIL-CLOSED: si OSRM no responde, no se publica.
MAPS_TIMEOUT_MS=

# Costo de referencia por km, por país (F1b · ESCUDO LEGAL anti-lucro, ADR-014 §8). Céntimos Int.
# ⚠️ VALORES PROVISIONALES — el DUEÑO debe VALIDARLOS con legal/finanzas ANTES de lanzar a prod
# (combustible + desgaste + peajes reales por país). Defaults del schema: PE=100 (S/1.00/km), EC=50.
COST_PER_KM_CENTS_PE=
COST_PER_KM_CENTS_EC=

# F2.5-v2 (ADR-017 §1.4): el costo/km del carpooling lo fija el admin DIRECTO por país (CostPerKmConfig = costo de
# operación real, combustible + desgaste). Ya NO se deriva del precio de energía de trip-service — el modelo de
# energía/combustible del PRICING fue REMOVIDO (2026-07); el on-demand usa un per-km all-in en su tarifa base.
# (Las keys del viejo camino energy-derived — TRIP_INTERNAL_URL / TRIP_INTERNAL_TIMEOUT_MS — se eliminaron.)
# TTL del cache in-proc del costo/km del admin (ms, default 10000).
COST_PER_KM_CACHE_TTL_MS=

OTEL_EXPORTER_OTLP_ENDPOINT=
# === gRPC interno · transporte TLS (mTLS) — ADR-016 ==========================
# Contrato OPCIONAL (default ausente = insecure). Las 3 rutas presentes -> mTLS
# (cifra + verifica el peer contra la CA interna). Ausentes (dev/test) -> texto
# plano; el HMAC sigue dando auth+integridad. Mezcla parcial (1-2 de 3) -> fail-fast.
# Se provisionan en el DEPLOY (CA interna + cert por servicio via SOPS+age /
# docker-secrets, paso de bootstrap-vps). Sin valores en la plantilla.
# GRPC_TLS_CA_PATH=/run/secrets/grpc-ca.pem
# GRPC_TLS_CERT_PATH=/run/secrets/grpc-svc.crt.pem
# GRPC_TLS_KEY_PATH=/run/secrets/grpc-svc.key.pem
# GRPC_TLS_REQUIRED=true   # enforcement: con la PKI provisionada, prod RECHAZA arrancar sin mTLS (ADR-016). Default false.

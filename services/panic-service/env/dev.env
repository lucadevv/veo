# panic-service · entorno DEV (tracked, sin secretos reales). Cargar antes de bootear en local.
# Convención del repo (igual que identity/places): config NO secreta acá; los secretos van en
# `dev.secret.env` (gitignored). En dev los defaults del env.schema ya bastan para arrancar.
NODE_ENV=development
PORT=3006
LOG_LEVEL=debug

# Base de datos (schema "panic") — veo-postgres en :5433.
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=panic
DATABASE_URL_REPLICA=postgresql://veo:veo_dev@localhost:5433/veo?schema=panic

# Redis (readiness + rate-limit de endpoints NO críticos; /panic nunca se throttlea) — veo-redis :6379.
REDIS_URL=redis://localhost:6379

# Kafka (outbox relay → panic.triggered / panic.acknowledged) — veo-kafka en :9094.
KAFKA_BROKERS=localhost:9094

# ── Evidencia S3 (Object Lock / WORM). Self-hosted: MinIO en dev (:9002). ──
# 'live' usa el cliente S3 real contra el endpoint; 'sandbox' no toca red (tests/CI offline).
VEO_EVIDENCE_MODE=live
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY=veo_dev
S3_BUCKET_EVIDENCE=veo-panic-evidence-dev
EVIDENCE_RETENTION_DAYS=365
EVIDENCE_KEYS_PER_PANIC=1

# Observabilidad (Jaeger OTLP del dev-stack).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# gRPC (lectura síncrona: veo.panic.v1).
GRPC_URL=0.0.0.0:50056

# Secretos: vacíos acá; los valores reales viven en dev.secret.env (gitignored).
INTERNAL_IDENTITY_SECRET=
PANIC_HMAC_SECRET=
S3_SECRET_KEY=

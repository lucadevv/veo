# rating-service · config DEV (tracked, SIN secretos). El INTERNAL_IDENTITY_SECRET vive en
# development.secret.env (gitignored), generado por dev-stack/boot-passenger-stack.sh (sincronizado con bff/identity).
NODE_ENV=development
PORT=3010
LOG_LEVEL=info

# Postgres compartido del dev-stack (contenedor veo-postgres, schema propio del servicio).
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=rating

# Redis + Kafka del dev-stack.
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9094

# gRPC server (agregado de rating para scoring; el bff apunta a RATING_GRPC_URL=localhost:50060 por default).
GRPC_URL=0.0.0.0:50060
# gRPC cliente a trip-service: valida el viaje en el submit de una calificación (existe + COMPLETED + participante).
TRIP_GRPC_URL=localhost:50052

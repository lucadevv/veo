// chat-service Â· esquema Postgres (schema lÃ³gico "chat")
// FOUNDATION Â§8. DueÃ±o de: mensajerÃ­a in-app conductorâ†”pasajero durante un viaje activo (Ola 2A).
// Persistencia simple; la entrega en tiempo real la hacen los BFFs reutilizando su Socket.IO.

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["chat"]
}

enum SenderRole {
  PASSENGER
  DRIVER

  @@schema("chat")
}

/// Mensaje de chat de un viaje. Solo entre las dos partes del viaje y mientras estÃ¡ activo
/// (la validaciÃ³n de membresÃ­a/estado la hacen los BFFs antes de persistir/leer).
model Message {
  id         String     @id @db.Uuid
  tripId     String     @map("trip_id") @db.Uuid
  senderId   String     @map("sender_id") @db.Uuid
  senderRole SenderRole @map("sender_role")
  body       String
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz

  @@index([tripId, createdAt])
  @@map("messages")
  @@schema("chat")
}

/// Outbox (FOUNDATION Â§6). El mensaje y el evento chat.message_sent se escriben en la MISMA
/// transacciÃ³n; un relay lo publica a Kafka. Ambos BFFs consumen el evento y lo emiten en su
/// Socket.IO (pÃºblico `/passenger`, conductor `/driver`) a la sala del viaje â†’ entrega en tiempo real.
model OutboxEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq         BigInt    @default(autoincrement())
  aggregateId String    @map("aggregate_id")
  eventType   String    @map("event_type")
  envelope    Json
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  publishedAt DateTime? @map("published_at") @db.Timestamptz
  claimedAt   DateTime? @map("claimed_at") @db.Timestamptz
  failedAt    DateTime? @map("failed_at") @db.Timestamptz

  @@index([publishedAt, failedAt, claimedAt, createdAt, seq], map: "outbox_events_claim_idx")
  @@map("outbox_events")
  @@schema("chat")
}

# chat-service · secretos DEV (PLANTILLA). Copiar a `development.env` (gitignored) y completar.
# En dev local los defaults del env.schema bastan; este archivo solo si querés sobreescribir el secreto.
INTERNAL_IDENTITY_SECRET=dev-internal-secret-change-me

# === Tier de despliegue ======================================================
# Tier lógico: local | dev | preview | production. Lo setea el runner (veo.sh exporta según APP_ENV;
# docker-compose.preview.yml lo pinea a preview vía environment). Este archivo puede fijarlo explícito
# (gana sobre el export del runner). @veo/utils deployTier() lo lee; default seguro = production.
# VEO_DEPLOY_TIER=dev

# chat-service · entorno DEV (tracked, sin secretos reales). Cargar antes de bootear en local.
# Convención del repo (igual que identity/places): config NO secreta acá; los secretos van en
# `development.secret.env` (gitignored). En dev los defaults del env.schema ya bastan para arrancar.
NODE_ENV=development
PORT=3014
LOG_LEVEL=debug

# Base de datos (schema "chat") — veo-postgres en :5433.
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo?schema=chat
DATABASE_URL_REPLICA=postgresql://veo:veo_dev@localhost:5433/veo?schema=chat

# Redis (readiness) — veo-redis en :6379.
REDIS_URL=redis://localhost:6379

# Kafka (outbox relay → chat.message_sent) — veo-kafka en :9094.
KAFKA_BROKERS=localhost:9094

# ── Dominio de chat (reglas de negocio, públicas) ──
CHAT_MAX_BODY_LENGTH=2000
CHAT_MAX_PAGE_SIZE=100

# Observabilidad (Jaeger OTLP del dev-stack).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Secreto: vacío acá; el valor real vive en development.secret.env (gitignored).
INTERNAL_IDENTITY_SECRET=

# ============================================================
# VEO Platform · Example environment variables
# Copia este archivo a .env y completa los valores.
# NUNCA commitear .env real. Solo .env.example.
# ============================================================

NODE_ENV=development
LOG_LEVEL=debug

# === Database ===
DATABASE_URL=postgresql://veo:veo_dev@localhost:5433/veo
DATABASE_URL_REPLICA=postgresql://veo:veo_dev@localhost:5433/veo

# === Redis ===
REDIS_URL=redis://localhost:6379
REDIS_PUBSUB_URL=redis://localhost:6379/1

# === Kafka ===
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=veo-dev
KAFKA_GROUP_ID=veo-dev-consumer

# === Auth / JWT ===
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# === MQTT (tracking) ===
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=veo
MQTT_PASSWORD=veo_dev

# === S3 / MinIO ===
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY=veo_dev
S3_SECRET_KEY=veo_dev_secret
S3_BUCKET_VIDEO=veo-video-dev
S3_BUCKET_AUDIT=veo-audit-dev
# Avatares (media-service): bucket de LECTURA PÚBLICA solo en el prefijo avatars/.
S3_BUCKET_AVATAR=veo-avatars-dev
# Base pública para componer la publicUrl estable del avatar (path-style, coherente con MinIO).
S3_PUBLIC_BASE_URL=http://localhost:9002
# Cuota de tamaño del avatar en bytes (se valida en el confirm tras la subida). 5 MiB.
AVATAR_MAX_BYTES=5242880

# === LiveKit (WebRTC) ===
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_in_production

# === Biometrics (FaceTec / Onfido) ===
FACETEC_DEVICE_KEY_IDENTIFIER=
FACETEC_PUBLIC_KEY=
ONFIDO_API_TOKEN=

# === Payments ===
YAPE_MERCHANT_ID=
YAPE_API_KEY=
PLIN_MERCHANT_ID=
PLIN_API_KEY=
NIUBIZ_MERCHANT_ID=
NIUBIZ_API_KEY=
CULQI_PUBLIC_KEY=
CULQI_PRIVATE_KEY=

# === Maps ===
GOOGLE_MAPS_API_KEY=

# === Notifications ===
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.veo.passenger
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SES_REGION=us-east-1
SES_FROM_EMAIL=noreply@veo.pe

# === Observability ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=
GRAFANA_URL=http://localhost:3001

# === Compliance / KMS ===
KMS_KEY_ID_VIDEO=alias/veo-video
KMS_KEY_ID_BIOMETRIC=alias/veo-biometric
KMS_KEY_ID_PII=alias/veo-pii

# === Service URLs (dev local) ===
IDENTITY_SERVICE_URL=http://localhost:3001
TRIP_SERVICE_URL=http://localhost:3002
DISPATCH_SERVICE_URL=http://localhost:3003
TRACKING_SERVICE_URL=http://localhost:3004
MEDIA_SERVICE_URL=http://localhost:3005
PAYMENT_SERVICE_URL=http://localhost:3006
PANIC_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008
AUDIT_SERVICE_URL=http://localhost:3009
RATING_SERVICE_URL=http://localhost:3010
SHARE_SERVICE_URL=http://localhost:3011
PUBLIC_BFF_URL=http://localhost:4001
DRIVER_BFF_URL=http://localhost:4002
ADMIN_BFF_URL=http://localhost:4003

# === BFF → downstream REST (base path /api/v1 incluido donde aplica) ===
# URL interna de media-service que los BFFs usan para proxyar avatar presign/confirm y media.
MEDIA_URL=http://localhost:3007/api/v1

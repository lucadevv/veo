+//
+//  VisionFaceDetectorCore.swift
+//  [PATCH VEO] Reemplazo de Google MLKit por Apple Vision framework.
+//
+//  Por qué: MLKit no publica slice arm64-simulator (su podspec inyecta
+//  EXCLUDED_ARCHS[sdk=iphonesimulator*]=arm64 al target de la app) y los runtimes de iOS 26
+//  son arm64-only → con MLKit linkeado la app no puede correr en NINGÚN simulador moderno.
+//  Además la regla de soberanía del proyecto exige el on-device sin SDK de terceros.
+//
+//  Contrato: misma forma JS (specs nitro generados intactos). El veredicto de liveness lo da
+//  SIEMPRE el servidor (biometric-service); esto es solo guía + autocaptura, así que las
+//  aproximaciones (p.ej. probabilidad de ojo abierto por EAR) son aceptables.
+//
+
+import Foundation
+import UIKit
+import Vision
+
+/// Config compartida del procesamiento por detección (dimensiones de la imagen ORIENTADA en px
+/// + escalas de autoMode). Misma semántica que la versión MLKit para no romper `bounds`.
+struct FaceProcessConfig {
+  let width: Double
+  let height: Double
+  let scaleX: Double
+  let scaleY: Double
+  let runLandmarks: Bool
+  let runContours: Bool
+  let runClassifications: Bool
+  let trackingEnabled: Bool
+
+  init(
+    width: Double,
+    height: Double,
+    scaleX: Double,
+    scaleY: Double,
+    runLandmarks: Bool,
+    runContours: Bool,
+    runClassifications: Bool,
+    trackingEnabled: Bool
+  ) {
+    self.width = width
+    self.height = height
+    self.scaleX = scaleX
+    self.scaleY = scaleY
+    self.runLandmarks = runLandmarks
+    self.runContours = runContours
+    self.runClassifications = runClassifications
+    self.trackingEnabled = trackingEnabled
+  }
+}
+
+/// Par (observación base con ángulos, observación enriquecida con landmarks). Vision reporta
+/// yaw/pitch/roll en el request de RECTÁNGULOS; los landmarks salen de un segundo request
+/// encadenado. Se conservan ambos para no perder ninguno de los dos conjuntos de datos.
+struct VisionDetectedFace {
+  let base: VNFaceObservation
+  let enriched: VNFaceObservation?
+
+  var landmarks: VNFaceLandmarks2D? { enriched?.landmarks ?? base.landmarks }
+}
+
+/// Motor de detección facial sobre Apple Vision. Sincrónico (Vision `perform` es sync); el
+/// caller decide la cola. Thread-safe por no tener estado mutable.
+final class VisionFaceDetectorCore {
+  private let needsLandmarks: Bool
+  private let minFaceSize: Double
+
+  /// `runClassifications` (probabilidad de ojo abierto) también exige landmarks: el EAR se
+  /// calcula desde los puntos del ojo.
+  init(
+    runLandmarks: Bool?,
+    runContours: Bool?,
+    runClassifications: Bool?,
+    minFaceSize: Double?
+  ) {
+    self.needsLandmarks =
+      (runLandmarks ?? false) || (runContours ?? false) || (runClassifications ?? false)
+    self.minFaceSize = minFaceSize ?? 0.15
+  }
+
+  /// Detecta rostros en el handler dado. Dos fases: rectángulos (bounds + yaw/pitch/roll) y,
+  /// si hacen falta, landmarks encadenados vía `inputFaceObservations` (matcheados por UUID).
+  func detect(with handler: VNImageRequestHandler) throws -> [VisionDetectedFace] {
+    let rectanglesRequest = VNDetectFaceRectanglesRequest()
+    try handler.perform([rectanglesRequest])
+    guard let observations = rectanglesRequest.results, !observations.isEmpty else {
+      return []
+    }
+
+    // minFaceSize (semántica MLKit): ancho mínimo del rostro como fracción del ancho de imagen.
+    // El boundingBox de Vision ya viene normalizado 0..1 → comparación directa.
+    let bigEnough = observations.filter { Double($0.boundingBox.width) >= minFaceSize }
+    guard !bigEnough.isEmpty else { return [] }
+
+    guard needsLandmarks else {
+      return bigEnough.map { VisionDetectedFace(base: $0, enriched: nil) }
+    }
+
+    let landmarksRequest = VNDetectFaceLandmarksRequest()
+    landmarksRequest.inputFaceObservations = bigEnough
+    try handler.perform([landmarksRequest])
+    let enrichedByUuid = Dictionary(
+      uniqueKeysWithValues: (landmarksRequest.results ?? []).map { ($0.uuid, $0) }
+    )
+    return bigEnough.map {
+      VisionDetectedFace(base: $0, enriched: enrichedByUuid[$0.uuid])
+    }
+  }
+}
+
+extension UIImage.Orientation {
+  /// UIImage.Orientation → CGImagePropertyOrientation (Vision consume EXIF/CG, no UIKit).
+  var cgImagePropertyOrientation: CGImagePropertyOrientation {
+    switch self {
+    case .up: return .up
+    case .down: return .down
+    case .left: return .left
+    case .right: return .right
+    case .upMirrored: return .upMirrored
+    case .downMirrored: return .downMirrored
+    case .leftMirrored: return .leftMirrored
+    case .rightMirrored: return .rightMirrored
+    @unknown default: return .up
+    }
+  }
+}
+
+extension CGImagePropertyOrientation {
+  /// true si la orientación rota 90°/270° (el ancho y alto de la imagen orientada se intercambian).
+  var swapsDimensions: Bool {
+    switch self {
+    case .left, .right, .leftMirrored, .rightMirrored: return true
+    default: return false
+    }
+  }
+}

{
  "name": "veo-passenger-app",
  "version": "0.1.0",
  "private": true,
  "description": "VEO Passenger · React Native iOS + Android",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "android": "ENVFILE=env/dev.secret.env react-native run-android",
    "ios": "ENVFILE=env/dev.secret.env react-native run-ios",
    "start": "react-native start",
    "dev": "react-native start --reset-cache",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e:android": "detox test --configuration android.emu.release",
    "test:e2e:ios": "detox test --configuration ios.sim.release",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:android:bundle": "cd android && ./gradlew bundleRelease",
    "build:ios": "xcodebuild -workspace ios/VEO.xcworkspace -scheme VEO -configuration Release",
    "pod:install": "cd ios && pod install",
    "clean": "rimraf node_modules ios/Pods android/.gradle"
  },
  "dependencies": {
    "@invertase/react-native-apple-authentication": "^2.5.1",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-native-firebase/app": "^21.0.0",
    "@react-native-firebase/messaging": "^21.0.0",
    "@react-native-google-signin/google-signin": "^13.3.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@reduxjs/toolkit": "^2.2.7",
    "@rnmapbox/maps": "10.2.1",
    "@tanstack/react-query": "^5.59.0",
    "@veo/api-client": "workspace:*",
    "@veo/shared-types": "workspace:*",
    "@veo/ui-kit": "workspace:*",
    "@veo/utils": "workspace:*",
    "axios": "^1.7.7",
    "i18next": "^23.15.2",
    "livekit-client": "^2.19.0",
    "react": "18.3.1",
    "react-i18next": "^15.0.2",
    "react-native": "0.75.4",
    "react-native-background-fetch": "~4.2.6",
    "react-native-background-geolocation": "^4.16.4",
    "react-native-config": "~1.5.3",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-image-picker": "7.2.3",
    "react-native-keychain": "^10.0.0",
    "react-native-mmkv": "^2.12.2",
    "react-native-reanimated": "~3.15.4",
    "react-native-safe-area-context": "~4.11.0",
    "react-native-screens": "~3.34.0",
    "react-native-svg": "15.8.0",
    "react-native-vision-camera": "4.6.1",
    "react-native-vision-camera-face-detector": "1.7.2",
    "react-native-webrtc": "^124.0.4",
    "react-native-worklets-core": "1.5.0",
    "react-redux": "^9.1.2",
    "socket.io-client": "^4.8.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0-rc.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.7",
    "@babel/preset-env": "^7.25.7",
    "@babel/runtime": "^7.25.7",
    "@eslint/js": "^9.13.0",
    "@react-native/babel-preset": "0.75.4",
    "@react-native/metro-config": "0.75.4",
    "@react-native/typescript-config": "0.75.4",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^29.5.13",
    "@types/react": "^18.3.11",
    "@types/react-test-renderer": "^18.3.0",
    "babel-jest": "^29.7.0",
    "detox": "^20.27.5",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "jest": "^29.7.0",
    "react-test-renderer": "18.3.1",
    "rimraf": "^6.0.1",
    "typescript": "5.6.2",
    "typescript-eslint": "^8.11.0"
  }
}

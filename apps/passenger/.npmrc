# React Native (autolinking, Metro, CocoaPods y Gradle) espera un node_modules
# plano. pnpm por defecto usa enlaces aislados que rompen el autolinking nativo,
# por eso forzamos el linker "hoisted".
node-linker=hoisted
shamefully-hoist=true
# Permite scripts de instalación de dependencias nativas (hermes, etc.).
enable-pre-post-scripts=true

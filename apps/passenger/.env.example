# VEO Passenger · variables de entorno (react-native-config)
# Copia a `.env` y reemplaza los valores. NO comitear `.env` con secretos.
# El pasajero SIEMPRE habla con el public-bff (nunca microservicios directos).

# REST del public-bff (incluye el prefijo /api/v1).
# Android emulador: 10.0.2.2 · iOS/simulador/device: localhost.
PUBLIC_BFF_URL=http://10.0.2.2:4001/api/v1

# Host del public-bff para Socket.IO (sin namespace; /passenger lo añade el cliente).
PUBLIC_BFF_WS_URL=http://10.0.2.2:4001

# WebRTC / LiveKit (token emitido por media-service). Vacío = video deshabilitado.
LIVEKIT_URL=wss://livekit.veo.pe

# Mapas — Mapbox (Lote 4: migración del pasajero a @rnmapbox/maps, gemelo del conductor).
# El estilo veo-dark se sirve desde el bundle JS (no es una URL), así que PUBLIC_MAP_STYLE_URL
# queda como fallback opcional legado. Lo único que la app necesita en runtime es el TOKEN PÚBLICO.
#
# MAPBOX_ACCESS_TOKEN: token público (empieza con `pk.`). Es público por diseño, pero NO se
# commitea: vive en `env/dev.secret.env` (gitignored). Copia este archivo a `.env` y rellénalo
# desde `env/dev.secret.env`. El `sk.` (download token de iOS, scope DOWNLOADS:READ) NO va aquí:
# es una credencial de máquina/CI que vive en `~/.netrc` (ver ios/install-mapbox.md).
MAPBOX_ACCESS_TOKEN=

# Estilo MapLibre OSCURO legado (tileserver-gl). Opcional: con Mapbox el estilo va embebido.
# Android emulador: 10.0.2.2 · iOS/simulador/device: localhost.
PUBLIC_MAP_STYLE_URL=http://10.0.2.2:8082/styles/veo-dark/style.json

# Firebase Cloud Messaging (true sólo con google-services.json / GoogleService-Info.plist reales).
FIREBASE_ENABLED=false

# Entorno: development | staging | production
VEO_ENV=development

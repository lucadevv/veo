# Passenger App - Example Environment Variables
PUBLIC_BFF_URL=http://192.168.18.227:4001/api/v1
PUBLIC_BFF_WS_URL=http://192.168.18.227:4001
PUBLIC_MAP_STYLE_URL=http://10.0.2.2:8082/styles/veo-dark/style.json

# LiveKit (WebRTC): vacío = video deshabilitado en dev. Se setea cuando el media-service emite tokens.
LIVEKIT_URL=

# FCM: deshabilitado por defecto en dev (sin credenciales reales). 'true' solo con Firebase configurado.
FIREBASE_ENABLED=

MAPBOX_ACCESS_TOKEN=

# Passenger App - Example Environment Variables
# En DEV lo mejor es dejar las URLs VACÍAS: la app auto-deriva el host del packager Metro (la IP
# viva de la Mac). OJO: react-native-config BAKEA estos valores en el build nativo (editar el .env
# no afecta al build instalado hasta el próximo build); por eso en __DEV__ con Metro vivo cualquier
# override cuyo host no sea el de Metro se IGNORA como stale (IP LAN rotada, dominio de túnel
# muerto, localhost en device físico). Ver DEV_FORCE_ENV_URLS abajo para forzar un host fijo.
PUBLIC_BFF_URL=http://192.168.18.227:4001/api/v1
PUBLIC_BFF_WS_URL=http://192.168.18.227:4001
PUBLIC_MAP_STYLE_URL=http://10.0.2.2:8082/styles/veo-dark/style.json

# Sólo dev: 'true' = honrar los overrides de URL del .env tal cual (staging/túnel/IP fija),
# desactivando el auto-sanado anti-stale. En release no tiene efecto (el .env manda siempre).
DEV_FORCE_ENV_URLS=

# LiveKit (WebRTC): vacío = video deshabilitado en dev. Se setea cuando el media-service emite tokens.
LIVEKIT_URL=

# FCM: deshabilitado por defecto en dev (sin credenciales reales). 'true' solo con Firebase configurado.
FIREBASE_ENABLED=

MAPBOX_ACCESS_TOKEN=

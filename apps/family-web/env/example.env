# VEO family-web · variables de entorno
# Copia este archivo a .env.local y ajusta los valores. Nada se hardcodea en el código.

# Base REST del public-bff usada desde el cliente (React Query, revalidación).
NEXT_PUBLIC_BFF_URL=http://localhost:4001/api/v1

# Base REST del public-bff para el render server-side (puede ser un host interno distinto).
# Si no se define, se usa NEXT_PUBLIC_BFF_URL.
PUBLIC_BFF_URL=http://localhost:4001/api/v1

# Origen del gateway Socket.IO del public-bff (namespace /family). Acepta http(s) o ws(s).
NEXT_PUBLIC_BFF_WS_URL=http://localhost:4001

# Tiles OSM self-hosted (soberanía: nunca Mapbox/Google).
# Plantilla XYZ raster, por ejemplo:
NEXT_PUBLIC_TILE_URL=https://tiles.veo.pe/styles/osm/{z}/{x}/{y}.png
# ...o una URL de style.json self-hosted (vector/raster; el ideal es el veo-light alineado al
# "Daylight Trust" de las apps), por ejemplo:
# NEXT_PUBLIC_TILE_URL=https://tiles.veo.pe/styles/veo-light/style.json

# Servidor LiveKit self-hosted (WebRTC). El token de acceso lo entrega el bff por viaje.
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.veo.pe

# Teléfono del botón de ayuda. Por defecto 105 (Policía Nacional del Perú).
NEXT_PUBLIC_HELP_PHONE=105

# --- Solo para Playwright e2e (integración contra bff real) ---
# URL de la app bajo prueba.
PLAYWRIGHT_BASE_URL=http://localhost:5100
# Tokens reales emitidos por el share-service/public-bff. Si faltan, esos tests se omiten.
# TEST_SHARE_TOKEN=
# TEST_EXPIRED_TOKEN=
# TEST_REVOKED_TOKEN=

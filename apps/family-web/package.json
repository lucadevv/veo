{
  "name": "@veo/family-web",
  "version": "0.1.0",
  "private": true,
  "description": "VEO Family · Página pública para ver viaje en vivo desde link firmado (sin app, sin login)",
  "scripts": {
    "dev": "next dev -p 5100",
    "build": "next build",
    "start": "next start -p 5100",
    "lint": "eslint src --no-error-on-unmatched-pattern --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "clean": "rimraf .next .turbo node_modules"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@veo/api-client": "workspace:*",
    "@veo/shared-types": "workspace:*",
    "@veo/utils": "workspace:*",
    "clsx": "^2.1.1",
    "livekit-client": "^2.5.6",
    "lucide-react": "^0.451.0",
    "maplibre-gl": "^4.7.1",
    "next": "15.5.19",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "socket.io-client": "^4.8.0",
    "tailwind-merge": "^2.5.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.16.10",
    "@veo/shared-config": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-config-next": "15.5.19",
    "postcss": "^8.4.47",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}

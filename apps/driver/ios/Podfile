# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Mapbox v11 distribuye XCFrameworks DINÁMICOS; sin `use_frameworks!` NO se embeben en el .app
# (→ runtime "native code not available"). Igual que el passenger: linkage estático por default
# (ejemplo oficial de @rnmapbox/maps).
linkage = (ENV['USE_FRAMEWORKS'] || 'static').to_sym
Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
use_frameworks! :linkage => linkage

# @react-native-firebase: los pods Swift de Firebase requieren module maps de
# GoogleUtilities para poder enlazarse como librerías estáticas (sin use_frameworks!).
$RNFirebaseAsStaticFramework = true

# ─── Mapbox (@rnmapbox/maps · migración RN 0.85) ─────────────────────────────────────────────────
# @rnmapbox/maps@10.3.1 default Mapbox iOS = `~> 11.20.1` (su package.json `mapbox.ios`), MISMA versión
# que Android (11.20.1) y que el passenger. DEBE coincidir: el Swift de rnmapbox usa APIs de Mapbox
# 11.20.x; una v11 más vieja rompe el build con "has no member". Mantener el pin al actualizar @rnmapbox/maps.
$RNMapboxMapsVersion = '~> 11.20.1'
#
# Mapbox v11.8.0+ ELIMINÓ el requisito del download token (sk.): release notes v11.8.0 →
# "Configuring Mapbox's secret token is no longer required when installing our SDKs". Por eso
# `pod install` resuelve con SOLO el pk. público — sin `~/.netrc` ni sk. El pk. de runtime vive en
# `env/dev.secret.env` (lo consume `Mapbox.setAccessToken`).

target 'VEODriver' do
  config = use_native_modules!

  # Con `use_frameworks! :linkage => :static` los pods se construyen como frameworks estáticos
  # (ya proveen module maps) → NO hacen falta los `:modular_headers` explícitos de Firebase
  # (igual que el passenger).

  # @rnmapbox/maps: hook previo a la instalación (configura el podspec de MapboxMaps). Debe ir antes
  # de `use_react_native!` para que CocoaPods resuelva la dependencia nativa de Mapbox.
  pre_install do |installer|
    $RNMapboxMaps.pre_install(installer) if defined?($RNMapboxMaps)
  end

  # ─── React Native desde FUENTE (no prebuilt) — igual que el passenger ───────────────────────────
  # RN 0.85 baja React-Core PREBUILT por default. Bajo `use_frameworks!` (necesario para Mapbox v11)
  # ese module map prebuilt rompe @react-native-firebase con "RCTPromiseRejectBlock must be imported
  # from module before required" (fix del maintainer de RNFirebase, issue #8657). ANTES de use_react_native!.
  ENV['RCT_USE_RN_DEP'] = '0'
  ENV['RCT_USE_PREBUILT_RNCORE'] = '0'

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'VEODriverTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # @rnmapbox/maps: hook posterior a la instalación (parchea los targets de Pods para MapboxMaps).
    $RNMapboxMaps.post_install(installer) if defined?($RNMapboxMaps)

    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Igual que el passenger: (1) MapboxMaps 11.x exige iOS 14+ y `react_native_post_install` resetea
    # el deployment target de los pods al mínimo de RN — elevamos cualquier target por debajo de 15.1
    # (mínimo de RN 0.85). (2) use_frameworks! + RNFirebase + -Werror: los headers de RNFB hacen
    # `#import <React/...>` no-modular dentro de un framework module → relajamos ese check.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_configuration|
        current = build_configuration.build_settings['IPHONEOS_DEPLOYMENT_TARGET']
        if current.nil? || current.to_f < 15.1
          build_configuration.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'
        end
        build_configuration.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      end
    end
  end
end

{
  "name": "veo-driver-app",
  "version": "0.1.0",
  "private": true,
  "description": "VEO Conductor · React Native (iOS + Android) · New Architecture",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "dev": "react-native start --reset-cache",
    "lint": "ESLINT_USE_FLAT_CONFIG=true eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "pod-install": "cd ios && bundle exec pod install",
    "test:e2e:android": "detox test --configuration android.emu.release",
    "test:e2e:ios": "detox test --configuration ios.sim.debug",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:android:bundle": "cd android && ./gradlew bundleRelease",
    "clean": "rimraf node_modules android/.gradle android/app/build ios/Pods ios/build"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "3.1.1",
    "@react-native-firebase/app": "24.1.0",
    "@react-native-firebase/messaging": "24.1.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@reduxjs/toolkit": "^2.2.7",
    "@rnmapbox/maps": "10.3.1",
    "@tanstack/react-query": "^5.59.0",
    "@veo/api-client": "workspace:*",
    "@veo/shared-types": "workspace:*",
    "@veo/ui-kit": "workspace:*",
    "@veo/utils": "workspace:*",
    "axios": "^1.7.7",
    "i18next": "^23.15.2",
    "livekit-client": "^2.19.0",
    "react": "19.2.7",
    "react-i18next": "^15.0.2",
    "react-native": "0.85.3",
    "react-native-background-fetch": "4.4.2",
    "react-native-background-geolocation": "5.1.1",
    "react-native-config": "1.6.1",
    "react-native-gesture-handler": "3.0.0",
    "react-native-get-random-values": "2.0.0",
    "react-native-keychain": "^10.0.0",
    "react-native-mmkv": "4.3.1",
    "react-native-reanimated": "4.4.1",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-webrtc": "124.0.7",
    "react-native-worklets": "0.9.1",
    "react-redux": "^9.1.2",
    "socket.io-client": "^4.8.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0-rc.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.7",
    "@babel/preset-env": "^7.25.7",
    "@babel/runtime": "^7.25.7",
    "@eslint/js": "^9.13.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.17",
    "@types/react-test-renderer": "^18.3.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "detox": "^20.27.5",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "jest": "^29.7.0",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.7",
    "rimraf": "^6.0.1",
    "typescript": "5.6.2",
    "typescript-eslint": "^8.11.0"
  }
}

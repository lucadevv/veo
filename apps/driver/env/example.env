# VEO Conductor · variables de entorno (react-native-config)
# Copia este archivo a `.env` y completa los valores reales.

# Backend BFF del conductor (REST bajo /api/v1 + Socket.IO namespace /driver).
# Android emulador alcanza el host por 10.0.2.2; iOS simulador por localhost.
DRIVER_BFF_URL=http://10.0.2.2:4002/api/v1
DRIVER_BFF_WS_URL=http://10.0.2.2:4002

# Entorno de ejecución: development | staging | production
APP_ENV=development

# LiveKit (WebRTC publisher) — el token lo emite media-service
LIVEKIT_URL=

# Mapas — Mapbox (Lote 0+1: migración a @rnmapbox/maps).
# El estilo veo-dark se sirve desde el bundle JS (no es una URL), así que MAP_STYLE_URL
# queda como fallback opcional. Lo único que la app necesita en runtime es el TOKEN PÚBLICO.
#
# MAPBOX_ACCESS_TOKEN: token público (empieza con `pk.`). Público por diseño → vive en el
# `env/<tier>.env` (single-file). Copiá este example.env al tier que uses y completá el valor.
# El `sk.` (download token de iOS, scope DOWNLOADS:READ) NO va aquí: es credencial de máquina/CI
# que vive en `~/.netrc` (ver ios/Podfile e ios/install-mapbox.md).
MAPBOX_ACCESS_TOKEN=

# Estilo/tiles legado (MapLibre). Opcional: con Mapbox el estilo va embebido en el bundle.
MAP_STYLE_URL=

# Canal de soporte al conductor (correo). Si se omite, usa el default `soporte@veo.pe`.
SUPPORT_EMAIL=soporte@veo.pe

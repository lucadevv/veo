# ── admin-web · variables de entorno ──
# Copia a .env.local y ajusta. NADA hardcodeado en el código.

# URL del admin-bff (SERVER-SIDE, jamás expuesta al navegador).
# Los Route Handlers proxean aquí adjuntando el Bearer de la cookie httpOnly.
ADMIN_BFF_URL=http://localhost:4003/api/v1

# Origen público del bff (solo si se necesita en CSP/cliente). Normalmente todo va por /api/bff.
NEXT_PUBLIC_BFF_URL=http://localhost:4003

# Websocket del admin-bff para Socket.IO (namespace /ops). Puede ser http(s); el cliente negocia ws.
NEXT_PUBLIC_BFF_WS_URL=http://localhost:4003

# Tileserver OSM self-hosted (MapLibre style.json). NUNCA Mapbox/Google.
# Ej. tileserver-gl: http://localhost:8082/styles/basic-preview/style.json
NEXT_PUBLIC_TILE_URL=http://localhost:8082/styles/basic-preview/style.json

# Centro y zoom inicial del mapa de operación (Lima por defecto). Opcionales.
NEXT_PUBLIC_MAP_CENTER_LON=-77.0428
NEXT_PUBLIC_MAP_CENTER_LAT=-12.0464
NEXT_PUBLIC_MAP_ZOOM=11

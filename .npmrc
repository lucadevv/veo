# Monorepo unificado backend + React Native.
# RN (autolinking, Metro, CocoaPods, Gradle) espera un node_modules PLANO; pnpm por
# defecto usa enlaces aislados que rompen el autolinking nativo. Forzamos "hoisted"
# para TODO el workspace (el backend NestJS/Next tolera el layout plano).
node-linker=hoisted
shamefully-hoist=true
# Permite scripts de instalación de dependencias nativas (hermes, etc.).
enable-pre-post-scripts=true

# Copiar a terraform.tfvars y NO commitear.
# NUNCA poner secretos aqui — los secretos viven en AWS Secrets Manager.

region      = "us-east-1"
env         = "prod"
owner       = "platform"
cost_center = "veo-prod"

vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

cluster_version = "1.31"

rds_instance_class       = "db.r6g.large"
rds_allocated_storage    = 100
redis_node_type          = "cache.r6g.large"
msk_broker_instance_type = "kafka.m7g.large"

# Restringir el acceso publico al API server de EKS (recomendado: VPN/bastion CIDR).
eks_public_access_cidrs = ["0.0.0.0/0"]

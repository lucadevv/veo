# example.env · Cloudflare OPS · CONTRATO (claves sin valores). Este SÍ va a git.
# Copialo a local.env (gitignored) y completá los valores ahí. NUNCA pongas valores reales acá.

# Token API que creaste (permisos: Tunnel·Edit, DNS·Edit, Zone·Read, SSL·Edit, zona yoveoapp.com).
CLOUDFLARE_API_TOKEN=
# Account ID (Cloudflare dashboard → barra derecha). Opcional: se puede derivar del token.
CLOUDFLARE_ACCOUNT_ID=
# Zona / dominio.
CLOUDFLARE_ZONE=yoveoapp.com
# (Se completa DESPUÉS, al crear el Tunnel) — token del connector para cloudflared en el VPS.
CLOUDFLARE_TUNNEL_TOKEN=

# Contrato del archivo de secretos de INFRA del VPS — vive como /opt/veo/.env (gitignored, NUNCA en git).
# Lo consume docker-compose.preview.yml via ${VAR:?} (fail-fast: si falta, `up` aborta con mensaje claro).
# Copialo a /opt/veo/.env EN EL VPS y rellená valores reales. Este example.env va tracked, CERO valores.
#
# Soberania (FOUNDATION §0.7c): estos secretos viven en el host del VPS o cifrados con SOPS+age,
# NUNCA en un SaaS de secretos (no AWS Secrets Manager).

# --- Postgres / ClickHouse (analitica) ---
CLICKHOUSE_PASSWORD=

# --- MinIO (almacenamiento de objetos self-hosted, reemplaza S3) ---
# MINIO_ROOT_USER tiene default en el compose; override solo si lo cambiaste.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# Clave maestra del CIFRADO AT-REST SOBERANO (SSE-S3 envelope · Ley 29733 · §0.7c). NO es AWS KMS — es el
# KMS interno de MinIO con NUESTRA clave. El bootstrap activa auto-encryption SSE-S3 en los buckets PII
# (video/documentos/panic/audit). Formato `nombre:base64(32 bytes)`. Generar con:
#   echo "veo-media-key:$(openssl rand -base64 32)"
# En prod la gestiona SOPS+age; rotación documentada (infra/CLAUDE.md regla 6). Si falta, el VPS NO arranca.
MINIO_KMS_SECRET_KEY=

# --- LiveKit (WebRTC self-hosted) — firma los tokens de la camara en vivo ---
LIVEKIT_API_SECRET=

# --- Cloudflare Tunnel (cloudflared) — UNICO ingreso publico al VPS ---
# Token del tunnel 'veo-preview' (Dashboard Cloudflare → Zero Trust → Tunnels, o infra/cloudflare/setup-preview-tunnel.mjs).
CLOUDFLARE_TUNNEL_TOKEN=

{
  "name": "veo",
  "version": "0.1.0",
  "private": true,
  "description": "VEO · Plataforma de movilidad segura · Monorepo (apps móviles + web + services + packages + infra)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "e2e:golden": "bash e2e/scripts/run-golden.sh",
    "e2e:golden:test": "pnpm --filter @veo/e2e e2e:golden",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "prepare": "husky",
    "dev-stack:up": "docker compose -f dev-stack/docker-compose.yml up -d",
    "dev-stack:down": "docker compose -f dev-stack/docker-compose.yml down",
    "dev-stack:logs": "docker compose -f dev-stack/docker-compose.yml logs -f",
    "dev-stack:reset": "docker compose -f dev-stack/docker-compose.yml down -v",
    "veo:up": "bash dev-stack/veo.sh up",
    "veo:down": "bash dev-stack/veo.sh down",
    "veo:status": "bash dev-stack/veo.sh status",
    "veo:monitor": "bash dev-stack/veo.sh monitor",
    "veo:logs": "bash dev-stack/veo.sh logs",
    "veo:restart": "bash dev-stack/veo.sh restart",
    "veo:migrate": "bash dev-stack/veo.sh migrate",
    "otp:viewer": "node dev-stack/otp-viewer/server.mjs",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "codegen": "turbo run codegen",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.16.10",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.11.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.10.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "pnpm": {
    "patchedDependencies": {
      "@react-native/gradle-plugin@0.85.3": "patches/@react-native__gradle-plugin@0.85.3.patch"
    },
    "overrides": {
      "multer": "^2.1.0",
      "ws@>=8.0.0 <8.21.0": "^8.21.0",
      "form-data@>=4.0.0 <4.0.6": "^4.0.6",
      "nodemailer": "^7.0.11"
    }
  }
}
